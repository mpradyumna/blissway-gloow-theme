{% doc %}
  @prompt
    Need a section which should take images. The images should be configurable. One image for desktop view another for mobile view. So it should be responsive to view port.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-responsive-image-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: block;
  }

  .ai-responsive-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: auto;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-responsive-image-desktop-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: {{ block.settings.image_fit }};
  }

  .ai-responsive-image-mobile-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: none;
    object-fit: {{ block.settings.image_fit }};
  }

  .ai-responsive-image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    height: {{ block.settings.placeholder_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-responsive-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.5;
  }

  .ai-responsive-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 6px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    backdrop-filter: blur(4px);
  }

  {% if block.settings.enable_overlay %}
    .ai-responsive-image-overlay-{{ ai_gen_id }} {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: {{ block.settings.overlay_color }};
      opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
      pointer-events: none;
      border-radius: {{ block.settings.border_radius }}px;
    }
  {% endif %}

  {% if block.settings.enable_content_overlay %}
    .ai-responsive-image-content-{{ ai_gen_id }} {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      text-align: center;
      color: {{ block.settings.content_color }};
      z-index: 2;
      max-width: 90%;
    }

    .ai-responsive-image-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size }}px;
      font-weight: bold;
      margin: 0 0 10px;
      line-height: 1.2;
    }

    .ai-responsive-image-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size }}px;
      margin: 0;
      line-height: 1.4;
    }
  {% endif %}

  @media screen and (max-width: {{ block.settings.mobile_breakpoint }}px) {
    .ai-responsive-image-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-responsive-image-mobile-{{ ai_gen_id }} {
      display: block;
    }

    {% if block.settings.enable_content_overlay %}
      .ai-responsive-image-heading-{{ ai_gen_id }} {
        font-size: {{ block.settings.heading_size_mobile }}px;
      }

      .ai-responsive-image-text-{{ ai_gen_id }} {
        font-size: {{ block.settings.text_size_mobile }}px;
      }
    {% endif %}
  }

  {% if block.settings.enable_hover_effect %}
    .ai-responsive-image-wrapper-{{ ai_gen_id }}:hover .ai-responsive-image-desktop-{{ ai_gen_id }},
    .ai-responsive-image-wrapper-{{ ai_gen_id }}:hover .ai-responsive-image-mobile-{{ ai_gen_id }} {
      transform: scale({{ block.settings.hover_scale | divided_by: 100.0 }});
      transition: transform 0.3s ease;
    }

    .ai-responsive-image-desktop-{{ ai_gen_id }},
    .ai-responsive-image-mobile-{{ ai_gen_id }} {
      transition: transform 0.3s ease;
    }
  {% endif %}
{% endstyle %}

<div
  class="ai-responsive-image-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.image_link != blank %}
    <a href="{{ block.settings.image_link }}" class="ai-responsive-image-wrapper-{{ ai_gen_id }}">
  {% else %}
    <div class="ai-responsive-image-wrapper-{{ ai_gen_id }}">
  {% endif %}

    {% if block.settings.desktop_image or block.settings.mobile_image %}
      {% if block.settings.desktop_image %}
        <img
          src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
          alt="{{ block.settings.desktop_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.desktop_image.width }}"
          height="{{ block.settings.desktop_image.height }}"
          class="ai-responsive-image-desktop-{{ ai_gen_id }}"
        >
      {% endif %}

      {% if block.settings.mobile_image %}
        <img
          src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
          alt="{{ block.settings.mobile_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.mobile_image.width }}"
          height="{{ block.settings.mobile_image.height }}"
          class="ai-responsive-image-mobile-{{ ai_gen_id }}"
        >
      {% elsif block.settings.desktop_image %}
        <img
          src="{{ block.settings.desktop_image | image_url: width: 1000 }}"
          alt="{{ block.settings.desktop_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.desktop_image.width }}"
          height="{{ block.settings.desktop_image.height }}"
          class="ai-responsive-image-mobile-{{ ai_gen_id }}"
        >
      {% endif %}
    {% else %}
      <div class="ai-responsive-image-placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-responsive-image-empty-state-{{ ai_gen_id }}">
          Add images for desktop and mobile views
        </div>
      </div>
    {% endif %}

    {% if block.settings.enable_overlay %}
      <div class="ai-responsive-image-overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.enable_content_overlay and block.settings.overlay_heading != blank or block.settings.overlay_text != blank %}
      <div class="ai-responsive-image-content-{{ ai_gen_id }}">
        {% if block.settings.overlay_heading != blank %}
          <h2 class="ai-responsive-image-heading-{{ ai_gen_id }}">{{ block.settings.overlay_heading }}</h2>
        {% endif %}
        {% if block.settings.overlay_text != blank %}
          <p class="ai-responsive-image-text-{{ ai_gen_id }}">{{ block.settings.overlay_text }}</p>
        {% endif %}
      </div>
    {% endif %}

  {% if block.settings.image_link != blank %}
    </a>
  {% else %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Responsive image",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "range",
      "id": "mobile_breakpoint",
      "min": 480,
      "max": 1020,
      "step": 20,
      "unit": "px",
      "label": "Mobile breakpoint",
      "default": 760
    },
    {
      "type": "url",
      "id": "image_link",
      "label": "Image link"
    },
    {
      "type": "header",
      "content": "Image style"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover"
        },
        {
          "value": "contain",
          "label": "Contain"
        },
        {
          "value": "fill",
          "label": "Fill"
        }
      ],
      "default": "cover"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "range",
      "id": "placeholder_height",
      "min": 200,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Placeholder height",
      "default": 400
    },
    {
      "type": "header",
      "content": "Hover effects"
    },
    {
      "type": "checkbox",
      "id": "enable_hover_effect",
      "label": "Enable hover zoom",
      "default": false
    },
    {
      "type": "range",
      "id": "hover_scale",
      "min": 100,
      "max": 120,
      "step": 5,
      "unit": "%",
      "label": "Hover scale",
      "default": 105
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "checkbox",
      "id": "enable_overlay",
      "label": "Enable color overlay",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 30
    },
    {
      "type": "header",
      "content": "Content overlay"
    },
    {
      "type": "checkbox",
      "id": "enable_content_overlay",
      "label": "Enable text overlay",
      "default": false
    },
    {
      "type": "text",
      "id": "overlay_heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "overlay_text",
      "label": "Text"
    },
    {
      "type": "color",
      "id": "content_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Heading size mobile",
      "default": 24
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Text size mobile",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Responsive image"
    }
  ]
}
{% endschema %}