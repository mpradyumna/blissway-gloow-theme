{% doc %}
  @prompt
    Generate a section that  can hold images it should support both desktop as well as mobile resolution image placeholders. It should support styling the backgroun with colors border colors radius , Give a placeholder for Image Heading and subtext. Allow sytling to be customized. Support fancy text if enabled. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-container-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    {% if block.settings.background_gradient != blank %}
      background-image: {{ block.settings.background_gradient }};
    {% endif %}
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-image-text-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-image-text-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    margin-bottom: {{ block.settings.content_spacing }}px;
  }

  .ai-image-text-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-text-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-image-text-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-text-content-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-text-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: {{ block.settings.heading_line_height }};
    text-transform: {{ block.settings.heading_transform }};
  }

  .ai-image-text-heading-{{ ai_gen_id }} .ai-fancy-text-{{ ai_gen_id }} {
    {% if block.settings.enable_fancy_text %}
      background: {{ settings.highlight_background_color }};
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    {% endif %}
  }

  .ai-image-text-subtext-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.subtext_color }};
    font-size: {{ block.settings.subtext_size }}px;
    line-height: {{ block.settings.subtext_line_height }};
    opacity: {{ block.settings.subtext_opacity | divided_by: 100.0 }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-text-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px {{ block.settings.padding_horizontal_mobile }}px;
      border-radius: {{ block.settings.border_radius_mobile }}px;
    }

    .ai-image-text-wrapper-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-image-text-image-wrapper-{{ ai_gen_id }} {
      border-radius: {{ block.settings.image_border_radius_mobile }}px;
      margin-bottom: {{ block.settings.content_spacing_mobile }}px;
    }

    .ai-image-text-image-{{ ai_gen_id }} {
      border-radius: {{ block.settings.image_border_radius_mobile }}px;
    }

    .ai-image-text-placeholder-{{ ai_gen_id }} {
      min-height: 300px;
      border-radius: {{ block.settings.image_border_radius_mobile }}px;
    }

    .ai-image-text-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: {{ block.settings.heading_spacing_mobile }}px;
    }

    .ai-image-text-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size_mobile }}px;
    }
  }
{% endstyle %}

<div
  class="ai-image-text-container-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-text-wrapper-{{ ai_gen_id }}">
    <div class="ai-image-text-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image_desktop != blank %}
        <picture>
          {% if block.settings.image_mobile != blank %}
            <source
              media="(max-width: 749px)"
              srcset="{{ block.settings.image_mobile | image_url: width: 750 }} 750w,
                      {{ block.settings.image_mobile | image_url: width: 1500 }} 1500w"
            >
          {% endif %}
          <img
            src="{{ block.settings.image_desktop | image_url: width: 1600 }}"
            srcset="{{ block.settings.image_desktop | image_url: width: 800 }} 800w,
                    {{ block.settings.image_desktop | image_url: width: 1600 }} 1600w,
                    {{ block.settings.image_desktop | image_url: width: 2400 }} 2400w"
            alt="{{ block.settings.image_desktop.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_desktop.width }}"
            height="{{ block.settings.image_desktop.height }}"
            class="ai-image-text-image-{{ ai_gen_id }}"
          >
        </picture>
      {% else %}
        <div class="ai-image-text-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-image-text-empty-state-{{ ai_gen_id }}">
            Add an image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-image-text-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        {% if block.settings.heading_tag == 'h1' %}
          <h1 class="ai-image-text-heading-{{ ai_gen_id }}">
            {% if block.settings.enable_fancy_text and block.settings.fancy_text_word != blank %}
              {{ block.settings.heading | replace: block.settings.fancy_text_word, '<span class="ai-fancy-text-' | append: ai_gen_id | append: '">' | append: block.settings.fancy_text_word | append: '</span>' }}
            {% else %}
              {{ block.settings.heading }}
            {% endif %}
          </h1>
        {% elsif block.settings.heading_tag == 'h2' %}
          <h2 class="ai-image-text-heading-{{ ai_gen_id }}">
            {% if block.settings.enable_fancy_text and block.settings.fancy_text_word != blank %}
              {{ block.settings.heading | replace: block.settings.fancy_text_word, '<span class="ai-fancy-text-' | append: ai_gen_id | append: '">' | append: block.settings.fancy_text_word | append: '</span>' }}
            {% else %}
              {{ block.settings.heading }}
            {% endif %}
          </h2>
        {% elsif block.settings.heading_tag == 'h3' %}
          <h3 class="ai-image-text-heading-{{ ai_gen_id }}">
            {% if block.settings.enable_fancy_text and block.settings.fancy_text_word != blank %}
              {{ block.settings.heading | replace: block.settings.fancy_text_word, '<span class="ai-fancy-text-' | append: ai_gen_id | append: '">' | append: block.settings.fancy_text_word | append: '</span>' }}
            {% else %}
              {{ block.settings.heading }}
            {% endif %}
          </h3>
        {% elsif block.settings.heading_tag == 'h4' %}
          <h4 class="ai-image-text-heading-{{ ai_gen_id }}">
            {% if block.settings.enable_fancy_text and block.settings.fancy_text_word != blank %}
              {{ block.settings.heading | replace: block.settings.fancy_text_word, '<span class="ai-fancy-text-' | append: ai_gen_id | append: '">' | append: block.settings.fancy_text_word | append: '</span>' }}
            {% else %}
              {{ block.settings.heading }}
            {% endif %}
          </h4>
        {% elsif block.settings.heading_tag == 'h5' %}
          <h5 class="ai-image-text-heading-{{ ai_gen_id }}">
            {% if block.settings.enable_fancy_text and block.settings.fancy_text_word != blank %}
              {{ block.settings.heading | replace: block.settings.fancy_text_word, '<span class="ai-fancy-text-' | append: ai_gen_id | append: '">' | append: block.settings.fancy_text_word | append: '</span>' }}
            {% else %}
              {{ block.settings.heading }}
            {% endif %}
          </h5>
        {% else %}
          <h6 class="ai-image-text-heading-{{ ai_gen_id }}">
            {% if block.settings.enable_fancy_text and block.settings.fancy_text_word != blank %}
              {{ block.settings.heading | replace: block.settings.fancy_text_word, '<span class="ai-fancy-text-' | append: ai_gen_id | append: '">' | append: block.settings.fancy_text_word | append: '</span>' }}
            {% else %}
              {{ block.settings.heading }}
            {% endif %}
          </h6>
        {% endif %}
      {% endif %}

      {% if block.settings.subtext != blank %}
        <div class="ai-image-text-subtext-{{ ai_gen_id }}">
          {{ block.settings.subtext }}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image",
      "info": "Optional. If not set, desktop image will be used on mobile."
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "image_border_radius_mobile",
      "label": "Image border radius (mobile)",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Image with heading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 16,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Size (mobile)",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "heading_transform",
      "label": "Transform",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "lowercase",
          "label": "Lowercase"
        },
        {
          "value": "capitalize",
          "label": "Capitalize"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "label": "Line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Bottom spacing",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "heading_spacing_mobile",
      "label": "Bottom spacing (mobile)",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Fancy text"
    },
    {
      "type": "checkbox",
      "id": "enable_fancy_text",
      "label": "Enable fancy text",
      "default": false,
      "info": "Apply gradient effect to a specific word in the heading"
    },
    {
      "type": "text",
      "id": "fancy_text_word",
      "label": "Word to highlight",
      "info": "Enter the exact word from the heading to apply the gradient effect"
    },
    {
      "type": "header",
      "content": "Subtext"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Add a description or additional details about your image</p>"
    },
    {
      "type": "range",
      "id": "subtext_size",
      "label": "Size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "subtext_size_mobile",
      "label": "Size (mobile)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "subtext_line_height",
      "label": "Line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.5
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "subtext_opacity",
      "label": "Opacity",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 85
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_spacing",
      "label": "Image to text spacing",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "content_spacing_mobile",
      "label": "Image to text spacing (mobile)",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient"
    },
    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "range",
      "id": "border_thickness",
      "label": "Border thickness",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Container border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "border_radius_mobile",
      "label": "Container border radius (mobile)",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Padding (desktop)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Padding (mobile)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "label": "Horizontal",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Image with text"
    }
  ],
  "tag": null
}
{% endschema %}
