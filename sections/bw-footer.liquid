<style>
  .footer {
    background: #f9f9f9;
    color: #000;
    padding: 64px 0 40px;
  }
  .footer .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
      gap: 40px;
    }
  }
  .footer__brand {
    padding-bottom: 40px;
  }
  @media (min-width: 768px) {
    .footer__brand { grid-column: auto; padding-bottom: 0; }
  }
  .footer__logo {
    font-family: var(--font-heading-family, var(--font-display, sans-serif));
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -.03em;
    color: #000;
    margin: 0 0 12px 0;
  }
  .footer__logo span { color: #10b981; }
  .footer__tagline {
    margin-top: 12px;
    font-size: .88rem;
    color: #666;
    line-height: 1.6;
    max-width: 260px;
    margin-bottom: 0;
  }

  /* Accordion Style Footer (Mobile) */
  .footer__accordion {
    border-top: 1px solid #e5e5e5;
  }
  .footer__accordion:last-of-type {
    border-bottom: 1px solid #e5e5e5;
  }
  @media (min-width: 768px) {
    .footer__accordion, .footer__accordion:last-of-type {
      border: none;
    }
  }

  .footer__accordion summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 28px 0;
    cursor: pointer;
    list-style: none;
  }
  .footer__accordion summary::-webkit-details-marker {
    display: none;
  }
  @media (min-width: 768px) {
    .footer__accordion summary {
      padding: 0;
      cursor: default;
      pointer-events: none;
      margin-bottom: 20px;
    }
  }

  .footer__heading {
    font-family: var(--font-heading-family, var(--font-display, sans-serif));
    font-size: 1.1rem;
    font-weight: 800;
    color: #000;
    letter-spacing: .02em;
    text-transform: uppercase;
    margin-bottom: 0;
  }

  .footer__chevron {
    width: 24px;
    height: 24px;
    stroke: #999;
    fill: none;
    stroke-width: 1.5;
    transition: transform 0.3s ease;
  }
  @media (min-width: 768px) {
    .footer__chevron {
      display: none;
    }
  }

  .footer__accordion[open] .footer__chevron {
    transform: rotate(180deg);
  }

  .footer__accordion-content {
    padding-bottom: 32px;
  }
  @media (min-width: 768px) {
    .footer__accordion-content {
      padding-bottom: 0;
    }
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .footer__links a {
    font-size: .9rem;
    color: #444;
    transition: color 160ms;
    text-decoration: none;
  }
  .footer__links a:hover { color: #000; }

  .footer__trust {
    margin-top: 64px;
    padding-top: 40px;
    border-top: 1px solid #e5e5e5;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 24px;
  }

  .footer__bottom {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid #e5e5e5;
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: center;
    text-align: center;
    font-size: .85rem;
    color: #666;
  }
  @media (min-width: 768px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer__payment {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .payment-badge {
    height: 24px;
    background: #eee;
    border-radius: 4px;
    padding: 4px 10px;
    font-size: .7rem;
    font-weight: 700;
    color: #555;
    letter-spacing: .05em;
    display: inline-flex;
    align-items: center;
  }
</style>

<footer class="footer" aria-label="Site footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <p class="footer__logo">{{ section.settings.logo_text | default: 'BLISS<span>WAY</span>' }}</p>
        <p class="footer__tagline">
          {{ section.settings.tagline | default: 'Smart everyday essentials. Curated for Indian homes. Backed by people who use them.' }}
        </p>
      </div>

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_list' -%}
            <details class="footer__accordion" {{ block.shopify_attributes }}>
              <summary>
                <p class="footer__heading">{{ block.settings.heading | default: block.settings.menu.title }}</p>
                <svg class="footer__chevron" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </summary>
              <div class="footer__accordion-content">
                {%- if block.settings.menu != blank -%}
                  <ul class="footer__links">
                    {%- for link in block.settings.menu.links -%}
                      <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                    {%- endfor -%}
                  </ul>
                {%- else -%}
                  <ul class="footer__links">
                    <li><a href="about.html">Our story</a></li>
                    <li><a href="#">Our philosophy</a></li>
                    <li><a href="#">Journal</a></li>
                    <li><a href="#">Contact us</a></li>
                  </ul>
                {%- endif -%}
              </div>
            </details>

          {%- when 'text' -%}
            <details class="footer__accordion" {{ block.shopify_attributes }}>
              <summary>
                <p class="footer__heading">{{ block.settings.heading | default: 'Help' }}</p>
                <svg class="footer__chevron" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </summary>
              <div class="footer__accordion-content">
                <div style="font-size: 0.9rem; color: #555; line-height: 1.6;">
                  {{ block.settings.text }}
                </div>
              </div>
            </details>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    {%- assign trust_blocks = section.blocks | where: 'type', 'trust_badge' -%}
    {%- if trust_blocks.size > 0 -%}
      <div class="footer__trust">
        {%- for block in trust_blocks -%}
          <div style="display: flex; align-items: center; gap: 12px; color: #444;" {{ block.shopify_attributes }}>
            {%- if block.settings.svg_icon != blank -%}
              {{ block.settings.svg_icon }}
            {%- else -%}
              <svg viewBox="0 0 24 24" style="width: 20px; height: 20px; stroke: #10b981; fill: none; stroke-width: 2.5;">
                <circle cx="12" cy="12" r="10" />
                <path d="M8 14s1.5 2 4 2 4-2 4-2" />
                <line x1="9" y1="9" x2="9.01" y2="9" />
                <line x1="15" y1="9" x2="15.01" y2="9" />
              </svg>
            {%- endif -%}
            <span style="font-size: 0.9rem; font-weight: 600">{{ block.settings.title | default: 'Trust Badge' }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="footer__trust">
        <div style="display: flex; align-items: center; gap: 12px; color: #444;">
          <svg viewBox="0 0 24 24" style="width: 20px; height: 20px; stroke: #10b981; fill: none; stroke-width: 2.5;">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
            <path d="M7 11V7a5 5 0 0 1 10 0v4" />
          </svg>
          <span style="font-size: 0.9rem; font-weight: 600">100% Secure Checkout</span>
        </div>
        <div style="display: flex; align-items: center; gap: 12px; color: #444;">
          <svg viewBox="0 0 24 24" style="width: 20px; height: 20px; stroke: #2563eb; fill: none; stroke-width: 2.5;">
            <polyline points="1 4 1 10 7 10" />
            <path d="M3.51 15a9 9 0 1 0 .49-3.44" />
          </svg>
          <span style="font-size: 0.9rem; font-weight: 600">7-Day Easy Returns</span>
        </div>
        <div style="display: flex; align-items: center; gap: 12px; color: #444;">
          <svg viewBox="0 0 24 24" style="width: 20px; height: 20px; stroke: #f59e0b; fill: none; stroke-width: 2.5;">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          <span style="font-size: 0.9rem; font-weight: 600">Shipped from Bangalore</span>
        </div>
      </div>
    {%- endif -%}

    <div class="footer__bottom">
      <p>
        © {{ 'now' | date: '%Y' }} Blissway Essentials. All Rights Reserved.
        <a href="#MainContent" aria-label="Back to top" style="margin-left: 20px; text-decoration: underline; font-weight: 600; color: #000;">&uarr; Back to Top</a>
      </p>
      <div class="footer__payment" aria-label="Accepted payment methods">
        {%- if shop.enabled_payment_types != empty -%}
          {%- for type in shop.enabled_payment_types -%}
            <span class="payment-badge">{{ type | capitalize }}</span>
          {%- endfor -%}
        {%- else -%}
          <span class="payment-badge">UPI</span>
          <span class="payment-badge">GPay</span>
          <span class="payment-badge">PhonePe</span>
          <span class="payment-badge">Paytm</span>
          <span class="payment-badge">COD</span>
          <span class="payment-badge">VISA</span>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const handleFooterAccordions = () => {
      if (window.innerWidth >= 768) {
        document.querySelectorAll('.footer__accordion').forEach(function(el) {
          el.setAttribute('open', '');
        });
      } else {
        document.querySelectorAll('.footer__accordion').forEach(function(el) {
          el.removeAttribute('open');
        });
      }
    };
    
    window.addEventListener('resize', handleFooterAccordions);
    handleFooterAccordions();
  });
</script>

{% schema %}
{
  "name": "BW Footer",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" },
    {
      "type": "header",
      "content": "Brand Info"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "BLISS<span>WAY</span>",
      "info": "Use <span> to highlight a part of the text."
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Smart everyday essentials. Curated for Indian homes. Backed by people who use them."
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Support",
          "info": "Leave blank to use the menu title."
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Help"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Questions about an order? Write to us at <strong><a href=\"mailto:care@blissway.online\">care@blissway.online</a></strong></p><p><a href=\"#\">WhatsApp Support</a><br>9:30 AM – 6:00 PM | Mon – Fri</p>"
        }
      ]
    },
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Badge Title",
          "default": "100% Secure Checkout"
        },
        {
          "type": "html",
          "id": "svg_icon",
          "label": "SVG Icon Code",
          "info": "Paste raw SVG code here. Leave blank to use a default icon."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BW Footer",
      "blocks": [
        { "type": "link_list" },
        { "type": "link_list" },
        { "type": "link_list" },
        { "type": "text" },
        { "type": "trust_badge" },
        { "type": "trust_badge" },
        { "type": "trust_badge" }
      ]
    }
  ]
}
{% endschema %}