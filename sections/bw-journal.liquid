<style>
  .bw-journal {
    padding: 6rem 0;
    
    font-family: var(--font-body-family);
  }
  .bw-journal__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .bw-journal__header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }
  @media (min-width: 768px) {
    .bw-journal__header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }
  .bw-journal__label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(var(--color-button));
    margin-bottom: 1rem;
    display: block;
  }
  .bw-journal__heading {
    font-family: var(--font-heading-family);
    font-size: calc(var(--font-heading-scale) * 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    
    margin: 0;
    max-width: 600px;
  }
  .bw-journal__heading span {
    color: rgb(var(--color-button));
    text-decoration: underline;
    text-decoration-color: rgba(var(--color-button), 0.2);
    text-underline-offset: 8px;
  }
  .bw-journal__view-all {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    
    text-decoration: none;
    border-bottom: 2px solid rgb(var(--color-button));
    padding-bottom: 0.25rem;
    transition: color 0.3s;
  }
  .bw-journal__view-all:hover {
    color: rgb(var(--color-button));
  }
  
  .bw-journal__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .bw-journal__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .bw-journal-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    group: hover;
  }
  .bw-journal-card__image-wrap {
    position: relative;
    aspect-ratio: {{ section.settings.image_ratio | default: '1/1' }};
    border-radius: 1.5rem;
    overflow: hidden;
    margin-bottom: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    background: rgb(var(--color-background)); /* Use theme background for contain */
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .bw-journal-card__image-wrap img {
    width: 100%; height: 100%;
    object-fit: contain; /* Ensure full image is visible */
    object-position: center;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    transform: scale(1);
  }
  .bw-journal-card:hover .bw-journal-card__image-wrap img {
    transform: scale(1.1);
  }
  .bw-journal-card__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.3), transparent);
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }
  .bw-journal-card:hover .bw-journal-card__image-overlay {
    opacity: 1;
  }
  .bw-journal-card__tag {
    position: absolute;
    top: 1rem; left: 1rem;
    background: #fff;
    
    font-size: 0.625rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
  }
  
  .bw-journal-card__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }
  .bw-journal-card__meta-dot {
    width: 4px; height: 4px;
    background: rgb(var(--color-button));
    border-radius: 50%;
  }
  .bw-journal-card__title {
    font-family: var(--font-heading-family);
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 1rem;
    transition: color 0.3s;
    color: rgb(var(--color-foreground));
  }
  .bw-journal-card:hover .bw-journal-card__title {
    color: rgb(var(--color-button));
  }
  .bw-journal-card__excerpt {
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0;
    color: rgba(var(--color-foreground), 0.7);
  }
</style>

<section class="bw-journal color-{{ section.settings.color_scheme }} gradient" data-aos="fade-up">
  <div class="bw-journal__container">
    <div class="bw-journal__header">
      <div>
        <span class="bw-journal__label">{{ section.settings.eyebrow }}</span>
        <h2 class="bw-journal__heading">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_link }}" class="bw-journal__view-all">{{ section.settings.btn_label }} &rarr;</a>
      {%- endif -%}
    </div>

    <div class="bw-journal__grid">
      {%- assign blog = blogs[section.settings.blog] -%}
      {%- if blog != blank and blog.articles_count > 0 -%}
        {%- for article in blog.articles limit: section.settings.post_limit -%}
          <a href="{{ article.url }}" class="bw-journal-card">
            <div class="bw-journal-card__image-wrap">
              {%- if article.image -%}
                {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
              <div class="bw-journal-card__image-overlay"></div>
              {%- if article.tags.size > 0 -%}
                <span class="bw-journal-card__tag">{{ article.tags.first }}</span>
              {%- endif -%}
            </div>
            <div>
              <div class="bw-journal-card__meta">
                <span>{{ article.published_at | time_tag: format: 'date' }}</span>
                <span class="bw-journal-card__meta-dot"></span>
                <span>{{ article.content | strip_html | split: ' ' | size | divided_by: 200 | at_least: 1 }} MIN READ</span>
              </div>
              <h3 class="bw-journal-card__title">{{ article.title }}</h3>
              <p class="bw-journal-card__excerpt">
                {%- if article.excerpt.size > 0 -%}
                  {{ article.excerpt | strip_html | truncatewords: 20 }}
                {%- else -%}
                  {{ article.content | strip_html | truncatewords: 20 }}
                {%- endif -%}
              </p>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <a href="#" class="bw-journal-card">
            <div class="bw-journal-card__image-wrap">
              {{ 'lifestyle-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
              <div class="bw-journal-card__image-overlay"></div>
              <span class="bw-journal-card__tag">Lifestyle</span>
            </div>
            <div>
              <div class="bw-journal-card__meta">
                <span>TODAY</span>
                <span class="bw-journal-card__meta-dot"></span>
                <span>5 MIN READ</span>
              </div>
              <h3 class="bw-journal-card__title">Sample Article Title {{ i }}</h3>
              <p class="bw-journal-card__excerpt">This is a placeholder excerpt for the blog post. Once you select a blog, real posts will appear here.</p>
            </div>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BW Journal",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" },
    { "type": "select", "id": "image_ratio", "label": "Image Aspect Ratio", 
      "options": [
        { "value": "16/10", "label": "Wide (16:10)" },
        { "value": "4/3", "label": "Standard (4:3)" },
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "4/5", "label": "Portrait (4:5)" }
      ],
      "default": "1/1"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Blissway Journal" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Insights for the <span>modern home</span>." },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "View all articles" },
    { "type": "url", "id": "btn_link", "label": "Button Link" },
    { "type": "blog", "id": "blog", "label": "Select Blog" },
    { "type": "range", "id": "post_limit", "label": "Posts to show", "min": 3, "max": 9, "step": 3, "default": 3 }
  ],
  "presets": [
    {
      "name": "BW Journal"
    }
  ]
}
{% endschema %}