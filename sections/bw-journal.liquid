<script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
<link rel="stylesheet" href="{{ 'quick-add.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'quick-add.css' | asset_url }}"></noscript>

<style>
  .bw-journal {
    padding: 6rem 0;
    font-family: var(--font-body-family);
  }
  .bw-journal__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .bw-journal__header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }
  @media (min-width: 768px) {
    .bw-journal__header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }
  .bw-journal__label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgb(var(--color-button));
    margin-bottom: 1rem;
    display: block;
  }
  .bw-journal__heading {
    font-family: var(--font-heading-family);
    font-size: calc(var(--font-heading-scale) * 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0;
    max-width: 600px;
    color: rgb(var(--color-foreground));
  }
  .bw-journal__heading span {
    color: rgb(var(--color-button));
    text-decoration: underline;
    text-decoration-color: rgba(var(--color-button), 0.2);
    text-underline-offset: 8px;
    text-decoration-thickness: 4px;
  }
  .bw-journal__view-all {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    border-bottom: 2px solid rgb(var(--color-button));
    padding-bottom: 0.25rem;
    transition: color 0.3s;
  }
  .bw-journal__view-all:hover {
    color: rgb(var(--color-button));
  }
  
  .bw-journal__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 768px) {
    .bw-journal__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .bw-journal-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    position: relative;
    height: 100%;
  }
  .bw-journal-card__link-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .bw-journal-card__text-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .bw-journal-card__content {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .bw-journal-card__image-wrap {
    position: relative;
    aspect-ratio: {{ section.settings.image_ratio | default: '1/1' }};
    border-radius: 1.5rem;
    overflow: hidden;
    margin-bottom: 1.5rem;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    background: rgb(var(--color-background));
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .bw-journal-card__image-wrap img {
    width: 100%; height: 100%;
    object-fit: contain;
    object-position: center;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    transform: scale(1);
  }
  .bw-journal-card:hover .bw-journal-card__image-wrap img {
    transform: scale(1.1);
  }
  .bw-journal-card__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.1), transparent);
    opacity: 0.3;
    transition: opacity 0.3s ease;
  }
  .bw-journal-card:hover .bw-journal-card__image-overlay {
    opacity: 0.5;
  }
  .bw-journal-card__tag {
    position: absolute;
    top: 1rem; left: 1rem;
    background: #fff;
    color: #121212;
    font-size: 0.625rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    z-index: 2;
  }
  
  .bw-journal-card__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.2rem;
    font-weight: 700;
    color: rgb(29 29 29 / 0.4);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }
  .bw-journal-card__meta-dot {
    width: 4px; height: 4px;
    background: rgb(var(--color-button));
    border-radius: 50%;
  }
  .bw-journal-card__title {
    font-family: var(--font-heading-family);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 1rem;
    transition: color 0.3s;
    color: rgb(var(--color-foreground));
    line-height: 1.375;
    font-size: 2rem;
    transition-property: color, background-color, border-color, text-decoration-color, fill, stroke, -webkit-text-decoration-color;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 150ms;
    margin-bottom: 0.75rem;
  }
  .bw-journal-card:hover .bw-journal-card__title {
    color: rgb(var(--color-button));
  }
  .bw-journal-card__excerpt {
    font-size: 1.4rem;
    line-height: 1.6;
    margin: 0;
    color: rgba(var(--color-foreground), 0.7);
  }

  /* Product Card styles */
  .bw-modal-opener-wrapper {
    margin-top: auto;
    display: block;
    position: relative;
    z-index: 3;
    padding-top: 1.5rem;
  }
  .bw-product-wrapper {
    display: flex;
    width: 100%;
    padding: 1.25rem;
    background-color: #f5f5f5;
    text-decoration: none;
    transition: all 0.2s ease-out;
    border-radius: 1.2rem;
    align-items: center;
    text-align: left;
    border: 1px solid rgba(0,0,0,0.05);
    box-shadow: none;
    cursor: pointer;
    font-family: inherit;
  }
  .bw-product-wrapper:active {
    transform: scale(0.98);
  }
  .bw-product-wrapper .img-wrapper {
    flex-shrink: 0;
    width: 50px;
    height: 50px;
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.05);
  }
  .bw-product-wrapper .img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .bw-product-wrapper-content {
    flex: 1;
    margin: 0 1.25rem;
    overflow: hidden;
  }
  .bw-product-label {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.4);
    margin-bottom: 0.25rem;
    display: block;
  }
  .bw-product-wrapper .title {
    margin: 0;
    color: rgb(var(--color-foreground));
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1.2;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .bw-product-wrapper:hover .title {
    color: rgb(var(--color-button));
  }
  .bw-product-wrapper .icon-wrapper {
    display: flex;
    transition: all 0.2s ease-out;
    color: rgba(var(--color-foreground), 0.4);
    margin-left: auto;
  }
</style>

<section class="bw-journal color-{{ section.settings.color_scheme }} gradient" data-aos="fade-up">
  <div class="bw-journal__container">
    <div class="bw-journal__header">
      <div>
        <span class="bw-journal__label">{{ section.settings.eyebrow }}</span>
        <h2 class="bw-journal__heading">{{ section.settings.heading }}</h2>
      </div>
      {%- if section.settings.btn_label != blank -%}
        <a href="{{ section.settings.btn_link }}" class="bw-journal__view-all">{{ section.settings.btn_label }} &rarr;</a>
      {%- endif -%}
    </div>

    <div class="bw-journal__grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          {%- assign article = block.settings.article -%}
          {%- if article != blank -%}
            <div class="bw-journal-card" {{ block.shopify_attributes }}>
              <div class="bw-journal-card__image-wrap">
                <a href="{{ article.url }}" class="bw-journal-card__link-overlay" aria-label="{{ article.title }}"></a>
                {%- if article.image -%}
                  {{ article.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
                <div class="bw-journal-card__image-overlay"></div>
                
                {%- if block.settings.custom_badge != blank -%}
                  <span class="bw-journal-card__tag" style="background-color: {{ block.settings.custom_badge_bg_color }}; color: #fff;">{{ block.settings.custom_badge }}</span>
                {%- elsif article.tags.size > 0 -%}
                  <span class="bw-journal-card__tag">{{ article.tags.first }}</span>
                {%- endif -%}
              </div>
              <div class="bw-journal-card__content">
                <a href="{{ article.url }}" class="bw-journal-card__text-link">
                  <div class="bw-journal-card__meta">
                    <span>{{ article.published_at | time_tag: format: 'date' }}</span>
                    <span class="bw-journal-card__meta-dot"></span>
                    <span>{{ article.content | strip_html | split: ' ' | size | divided_by: 200 | at_least: 1 }} MIN READ</span>
                  </div>
                  <h3 class="bw-journal-card__title">{{ article.title }}</h3>
                  <p class="bw-journal-card__excerpt">
                    {%- if article.excerpt.size > 0 -%}
                      {{ article.excerpt | strip_html | truncatewords: 20 }}
                    {%- else -%}
                      {{ article.content | strip_html | truncatewords: 20 }}
                    {%- endif -%}
                  </p>
                </a>

                {%- if block.settings.product != blank -%}
                  {%- assign product = block.settings.product -%}
                  {%- assign product_form_id = 'quick-add-' | append: section.id | append: product.id | append: '-' | append: forloop.index -%}
                  <modal-opener data-modal="#QuickAdd-{{ product.id }}-{{ section.id }}-{{ forloop.index }}" class="bw-modal-opener-wrapper" onclick="event.preventDefault();">
                    <button
                      id="{{ product_form_id }}-submit"
                      type="submit"
                      name="add"
                      class="bw-product-wrapper full-unstyled-link"
                      aria-haspopup="dialog"
                      aria-labelledby="{{ product_form_id }}-submit title-{{ section.id }}-{{ product.id }}"
                      data-product-url="{{ product.url }}"
                    >
                      <div class="img-wrapper">
                        {%- if product.featured_image -%}
                          <img
                            src="{{ product.featured_image | image_url: width: 120, height: 120, crop: 'center' }}"
                            class="img-fluid d-block"
                            alt="{{ product.featured_image.alt | escape }}"
                            width="60"
                            height="60"
                            loading="lazy"
                          >
                        {%- endif -%}
                      </div>
                      <div class="bw-product-wrapper-content">
                        <span class="bw-product-label">Featured Product</span>
                        <h4 class="title">
                          {{ product.title }} &rarr;
                        </h4>
                      </div>
                      <div class="icon-wrapper">
                        {% render 'lm-svg-icons', icon: 'eye', size: 16 %}
                      </div>
                      {%- render 'loading-spinner' -%}
                    </button>
                  </modal-opener>
                  <quick-add-modal id="QuickAdd-{{ product.id }}-{{ section.id }}-{{ forloop.index }}" class="quick-add-modal">
                    <div
                      role="dialog"
                      aria-label="{{ 'products.product.choose_product_options' | t: product_name: product.title | escape }}"
                      aria-modal="true"
                      class="quick-add-modal__content global-settings-popup"
                      tabindex="-1"
                    >
                      <button
                        id="ModalClose-{{ product.id }}-{{ section.id }}-{{ forloop.index }}"
                        type="button"
                        class="quick-add-modal__toggle"
                        aria-label="{{ 'accessibility.close' | t }}"
                      >
                        {{- 'icon-close.svg' | inline_asset_content -}}
                      </button>
                      <div id="QuickAddInfo-{{ product.id }}-{{ section.id }}-{{ forloop.index }}" class="quick-add-modal__content-info"></div>
                    </div>
                  </quick-add-modal>
                {%- endif -%}
              </div>
            </div>
          {%- else -%}
            <!-- Placeholder -->
            <div class="bw-journal-card" {{ block.shopify_attributes }}>
              <div class="bw-journal-card__image-wrap">
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
                <div class="bw-journal-card__image-overlay"></div>
                <span class="bw-journal-card__tag">Lifestyle</span>
              </div>
              <div class="bw-journal-card__content">
                <a href="#" class="bw-journal-card__text-link">
                  <div class="bw-journal-card__meta">
                    <span>TODAY</span>
                    <span class="bw-journal-card__meta-dot"></span>
                    <span>5 MIN READ</span>
                  </div>
                  <h3 class="bw-journal-card__title">Select an article in theme editor</h3>
                  <p class="bw-journal-card__excerpt">This is a placeholder excerpt for the blog post.</p>
                </a>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        <!-- Global placeholders -->
        {%- for i in (1..3) -%}
          <div class="bw-journal-card">
            <div class="bw-journal-card__image-wrap">
              {{ 'lifestyle-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
              <div class="bw-journal-card__image-overlay"></div>
              <span class="bw-journal-card__tag">Lifestyle</span>
            </div>
            <div class="bw-journal-card__content">
              <a href="#" class="bw-journal-card__text-link">
                <div class="bw-journal-card__meta">
                  <span>TODAY</span>
                  <span class="bw-journal-card__meta-dot"></span>
                  <span>5 MIN READ</span>
                </div>
                <h3 class="bw-journal-card__title">Sample Article Title {{ i }}</h3>
                <p class="bw-journal-card__excerpt">This is a placeholder excerpt for the blog post. Add article blocks to populate.</p>
              </a>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BW Journal",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" },
    { "type": "select", "id": "image_ratio", "label": "Image Aspect Ratio", 
      "options": [
        { "value": "16/10", "label": "Wide (16:10)" },
        { "value": "4/3", "label": "Standard (4:3)" },
        { "value": "1/1", "label": "Square (1:1)" },
        { "value": "4/5", "label": "Portrait (4:5)" }
      ],
      "default": "1/1"
    },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Blissway Journal" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Insights for the <span>modern home</span>." },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "View all articles" },
    { "type": "url", "id": "btn_link", "label": "Button Link" }
  ],
  "blocks": [
    {
      "type": "article",
      "name": "Article",
      "settings": [
        {
          "type": "article",
          "id": "article",
          "label": "Article"
        },
        {
          "type": "header",
          "content": "Product Card"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "header",
          "content": "Custom badge"
        },
        {
          "type": "text",
          "id": "custom_badge",
          "label": "Text",
          "info": "Leave empty to disable. E.g. NEW"
        },
        {
          "type": "color",
          "id": "custom_badge_bg_color",
          "label": "Bg color",
          "default": "#334FB4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BW Journal",
      "blocks": [
        { "type": "article" },
        { "type": "article" },
        { "type": "article" }
      ]
    }
  ]
}
{% endschema %}