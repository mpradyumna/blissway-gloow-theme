<section class="relative py-32 bg-fixed bg-cover bg-center overflow-hidden color-{{ section.settings.color_scheme }} gradient" style="background-image: url('{% if section.settings.bg_image != blank %}{{ section.settings.bg_image | image_url: width: 2000 }}{% else %}{{ 'about-lifestyle.png' | asset_url }}{% endif %}');" data-aos="fade-up">
  <div class="absolute inset-0 bg-black/20"></div>
  <div class="relative max-w-7xl mx-auto px-4 z-10" style="max-width: 1200px; margin: 0 auto;">
    <div class="max-w-3xl bg-white/95 backdrop-blur-xl p-10 md:p-16 rounded-3xl shadow-2xl border border-white/20 transform transition-transform duration-700 hover:scale-[1.02]" style="max-width: 800px; padding: 60px;  border-radius: 24px; box-shadow: 0 20px 40px rgba(var(--color-foreground), 0.1);">
      <span class="text-primary font-bold text-xs uppercase tracking-[0.2em] mb-4 block" style=" font-weight: var(--font-heading-weight); font-family: var(--font-heading-family); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.2em; margin-bottom: 1rem; display: block;">{{ section.settings.eyebrow }}</span>
      <blockquote class="text-3xl md:text-5xl font-bold tracking-tight leading-tight mb-8 text-text" style="font-size: 2.5rem; font-family: var(--font-heading-family); font-weight: var(--font-heading-weight); line-height: 1.2; margin-bottom: 2rem; ">
        {{ section.settings.heading }}
      </blockquote>
      <div class="text-lg text-text/70 leading-relaxed mb-10" style=" font-family: var(--font-body-family); font-weight: var(--font-body-weight);  line-height: 1.7; margin-bottom: 2.5rem;">
        {{ section.settings.text }}
      </div>
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="inline-flex items-center gap-3 px-8 py-4 bg-text text-white font-bold rounded-xl hover:bg-primary transition-all duration-300 uppercase tracking-widest text-xs shadow-xl shadow-black/10 group" style="display: inline-flex; align-items: center; gap: 0.75rem; padding: 1rem 2rem; background: rgb(var(--color-button)); color: rgb(var(--color-button-text)); font-family: var(--font-button-family); font-weight: var(--font-button-weight); border-radius: 12px; text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.75rem; text-decoration: none;">
          {{ section.settings.button_label }}
          <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" aria-hidden="true" style="width: 20px; height: 20px;">
            <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BW Our Philosophy",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Philosophy"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "\"We don't list products. We live with them first — and only sell what we'd recommend to our own families.\""
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Every product in the Blissway catalogue is tested in real Indian homes before it ships. If it doesn't hold up to daily life — the heat, the humidity, the long hours — it doesn't make the cut.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Our Story & Standards"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "BW Our Philosophy"
    }
  ]
}
{% endschema %}