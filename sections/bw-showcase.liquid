{%- style -%}
  .bw-showcase {
    display: flex;
    align-items: flex-start;
    background-color: rgb(var(--color-background));
    position: relative;
  }

  /* ── Left sticky lifestyle panel ── */
  .bw-showcase__left {
    position: sticky;
    top: 0;
    width: 42%;
    height: 100vh;
    flex-shrink: 0;
    overflow: hidden;
  }

  .card--card .quick-add {
    margin: 0 1.3rem 1rem;
}

.quick-add {
    position: relative;
    grid-row-start: 4;
    margin: 0 0 1rem;
    z-index: 1;
}

  .bw-showcase__left img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .bw-showcase__left-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(var(--color-foreground), 0.68) 0%, rgba(var(--color-foreground), 0.04) 55%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2.5rem;
  }

  .bw-showcase__eyebrow {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    margin: 0 0 0.5rem;
  }

  .bw-showcase__heading {
    font-family: var(--font-heading-family);
    font-size: calc(var(--font-heading-scale) * 3.5rem);
    font-weight: 700;
    color: #fff;
    line-height: 0.95;
    margin: 0 0 1.75rem;
  }

  .bw-showcase__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.4);
    padding-bottom: 0.2rem;
    width: fit-content;
    transition: border-color 0.25s;
  }
  .bw-showcase__cta:hover { border-color: #fff; }

  /* ── Right: grid ── */
  .bw-showcase__right {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
  }

  .bw-showcase__grid {
    width: 100%;
    padding: 3rem 2rem 3rem;
  }

  .bw-showcase__grid-inner {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  /* Theme card styling integration */
  .bw-showcase__grid-inner .card-wrapper {
    height: 100%;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .bw-showcase {
      flex-direction: column;
    }

    .bw-showcase__left {
      position: relative;
      width: 100%;
      height: 80vw;
      flex-shrink: 0;
    }

    .bw-showcase__left-overlay {
      padding: 1.5rem;
    }

    .bw-showcase__heading {
      font-size: 2.2rem;
    }

    .bw-showcase__right {
      width: 100%;
    }

    .bw-showcase__grid {
      padding: 2rem 1rem 2rem;
    }

    .bw-showcase__grid-inner {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 1rem;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .bw-showcase__grid-inner::-webkit-scrollbar { display: none; }

    .bw-showcase__grid-inner > * {
      flex: 0 0 82vw;
      scroll-snap-align: start;
    }
  }
{%- endstyle -%}

<section class="bw-showcase color-{{ section.settings.color_scheme }} gradient" id="Showcase-{{ section.id }}" data-section-id="{{ section.id }}">
  <!-- Left: Sticky lifestyle panel -->
  <div class="bw-showcase__left">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.heading }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
    
    <div class="bw-showcase__left-overlay">
      {%- if section.settings.eyebrow != blank -%}
        <p class="bw-showcase__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      
      {%- if section.settings.heading != blank -%}
        <h2 class="bw-showcase__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link }}" class="bw-showcase__cta">
          {{ section.settings.cta_label }}
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {%- endif -%}
    </div>
  </div>

  <!-- Right: Product grid -->
  <div class="bw-showcase__right">
    <div class="bw-showcase__grid" id="ProductGrid-{{ section.id }}">
      <div class="bw-showcase__grid-inner">
        {%- if section.settings.collection != blank -%}
          {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
            <div class="bw-showcase__item">
              {%- assign quick_add_mode = 'none' -%}
              {%- if section.settings.enable_quick_add -%}
                {%- assign quick_add_mode = 'standard' -%}
              {%- endif -%}
              {% render 'card-product',
                card_product: product,
                show_vendor: section.settings.show_vendor,
                show_rating: section.settings.show_rating,
                quick_add: quick_add_mode,
                section_id: section.id
              %}
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..section.settings.products_to_show) -%}
            <div class="bw-showcase__item">
              {% render 'card-product',
                show_vendor: section.settings.show_vendor,
                show_rating: section.settings.show_rating,
                section_id: section.id
              %}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BW - Alpine Showcase",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" },
    {
      "type": "header",
      "content": "Lifestyle Panel (Left)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Discover"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bestselling Products"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label",
      "default": "View all"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },
    {
      "type": "header",
      "content": "Product Grid (Right)"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" }
      ],
      "default": "square",
      "label": "Image ratio"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "Show second image on hover"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "default": false,
      "label": "Show vendor"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "Show product rating"
    },
    {
      "type": "checkbox",
      "id": "enable_quick_add",
      "default": false,
      "label": "Enable quick add button"
    }
  ],
  "presets": [
    {
      "name": "BW - Alpine Showcase"
    }
  ]
}
{% endschema %}