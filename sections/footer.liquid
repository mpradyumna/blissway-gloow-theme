
{% comment %}
  Gloow Footer replaced with prototype footer
{% endcomment %}

<style>
.footer {
  background: #f9f9f9;
  color: #000;
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  margin-top: {{ section.settings.margin_top }}px;
}

.footer__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
}

@media (min-width: 768px) {
  .footer__grid {
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 40px;
  }
}

.footer__brand {
  padding-bottom: 40px;
}

@media (min-width: 768px) {
  .footer__brand { grid-column: auto; padding-bottom: 0; }
}

.footer__logo {
  font-family: var(--font-heading-family, var(--font-body-family, sans-serif));
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: -.03em;
  color: #000;
  margin: 0;
}

.footer__logo span { color: var(--color-base-accent-1, #000); }

.footer__tagline {
  margin-top: 12px;
  font-size: .88rem;
  color: #666;
  line-height: 1.6;
  max-width: 260px;
}

/* Accordion Style Footer (Mobile) */
.footer__accordion {
  border-top: 1px solid #e5e5e5;
}
.footer__accordion:last-of-type {
  border-bottom: 1px solid #e5e5e5;
}

@media (min-width: 768px) {
  .footer__accordion, .footer__accordion:last-of-type {
    border: none;
  }
}

.footer__accordion summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28px 0;
  cursor: pointer;
  list-style: none;
}
.footer__accordion summary::-webkit-details-marker {
  display: none;
}
@media (min-width: 768px) {
  .footer__accordion summary {
    padding: 0;
    cursor: default;
    pointer-events: none;
    margin-bottom: 20px;
  }
}

.footer__heading {
  font-family: var(--font-heading-family, var(--font-body-family, sans-serif));
  font-size: 1.1rem;
  font-weight: 800;
  color: #000;
  letter-spacing: .02em;
  text-transform: uppercase;
  margin-bottom: 0;
}

.footer__chevron {
  width: 24px;
  height: 24px;
  stroke: #999;
  fill: none;
  stroke-width: 1.5;
  transition: transform 0.3s ease;
}

@media (min-width: 768px) {
  .footer__chevron {
    display: none;
  }
}

.footer__accordion[open] .footer__chevron {
  transform: rotate(180deg);
}

.footer__accordion-content {
  padding-bottom: 32px;
}

@media (min-width: 768px) {
  .footer__accordion-content {
    padding-bottom: 0;
  }
  .footer__accordion[open] .footer__accordion-content,
  .footer__accordion:not([open]) .footer__accordion-content {
    display: block;
  }
}

.footer__links {
  display: flex;
  flex-direction: column;
  gap: 14px;
  list-style: none;
  padding: 0;
  margin: 0;
}

.footer__links a {
  font-size: .9rem;
  color: #444;
  transition: color 160ms;
  text-decoration: none;
}

.footer__links a:hover { color: #000; }

.footer__bottom {
  margin-top: 64px;
  padding-top: 32px;
  border-top: 1px solid #e5e5e5;
  display: flex;
  flex-direction: column;
  gap: 20px;
  align-items: center;
  text-align: center;
  font-size: .85rem;
  color: #666;
}

@media (min-width: 768px) {
  .footer__bottom {
    flex-direction: row;
    justify-content: space-between;
    text-align: left;
    margin-top: 40px;
  }
}

.footer__payment {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
  justify-content: center;
}

.payment-badge {
  height: 24px;
  background: #eee;
  border-radius: 4px;
  padding: 4px 10px;
  font-size: .7rem;
  font-weight: 700;
  color: #555;
  letter-spacing: .05em;
  display: inline-flex;
  align-items: center;
}

.footer__trust {
  margin-top: 64px;
  padding-top: 40px;
  border-top: 1px solid #e5e5e5;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 24px;
}
.footer__trust-item {
  display: flex;
  align-items: center;
  gap: 12px;
  color: #444;
}
.footer__trust-icon {
  width: 20px;
  height: 20px;
  fill: none;
  stroke-width: 2.5;
}
.footer__trust-text {
  font-size: 0.9rem;
  font-weight: 600;
}
</style>

<footer class="footer" aria-label="Site footer">
  <div class="page-width container">
    <div class="footer__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'brand_information' -%}
            <div class="footer__brand" {{ block.shopify_attributes }}>
              <p class="footer__logo">
                {%- if settings.brand_headline != blank -%}
                  {{ settings.brand_headline }}
                {%- else -%}
                  BLISS<span>WAY</span>
                {%- endif -%}
              </p>
              {%- if settings.brand_description != blank -%}
                <div class="footer__tagline">{{ settings.brand_description }}</div>
              {%- else -%}
                <p class="footer__tagline">
                  Smart everyday essentials. Curated for Indian homes. Backed by people who use them.
                </p>
              {%- endif -%}
            </div>
            
          {%- when 'link_list' -%}
            <details class="footer__accordion" {{ block.shopify_attributes }}>
              <summary>
                <p class="footer__heading">{{ block.settings.heading | default: block.settings.menu.title }}</p>
                <svg class="footer__chevron" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </summary>
              <div class="footer__accordion-content">
                {%- if block.settings.menu != blank -%}
                  <ul class="footer__links">
                    {%- for link in block.settings.menu.links -%}
                      <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>
            </details>
            
          {%- when 'text' -%}
            <details class="footer__accordion" {{ block.shopify_attributes }}>
              <summary>
                <p class="footer__heading">{{ block.settings.heading }}</p>
                <svg class="footer__chevron" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </summary>
              <div class="footer__accordion-content">
                <div style="font-size: 0.9rem; color: #555; line-height: 1.6;">
                  {{ block.settings.subtext }}
                </div>
              </div>
            </details>
            
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="footer__trust">
      <div class="footer__trust-item">
        <svg class="footer__trust-icon" viewBox="0 0 24 24" style="stroke: #10b981;">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
        <span class="footer__trust-text">100% Secure Checkout</span>
      </div>
      <div class="footer__trust-item">
        <svg class="footer__trust-icon" viewBox="0 0 24 24" style="stroke: #2563eb;">
          <polyline points="1 4 1 10 7 10" />
          <path d="M3.51 15a9 9 0 1 0 .49-3.44" />
        </svg>
        <span class="footer__trust-text">7-Day Easy Returns</span>
      </div>
      <div class="footer__trust-item">
        <svg class="footer__trust-icon" viewBox="0 0 24 24" style="stroke: #f59e0b;">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        <span class="footer__trust-text">Shipped from Bangalore</span>
      </div>
    </div>

    <div class="footer__bottom">
      <p style="margin: 0;">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All Rights Reserved.
        <a href="#MainContent" aria-label="Back to top" style="margin-left: 20px; text-decoration: underline; font-weight: 600; color: #000;">&uarr; Back to Top</a>
      </p>
      
      {%- if section.settings.payment_enable -%}
        <div class="footer__payment" aria-label="Accepted payment methods">
          {%- if section.settings.original == 'custom' and section.settings.payment_icon != blank -%}
             {%- assign payment_icons = section.settings.payment_icon | split: ',' -%}
             {%- for icon in payment_icons -%}
               <span class="payment-badge">{{ icon | strip | upcase | replace: '-', ' ' | replace: '_', ' ' }}</span>
             {%- endfor -%}
          {%- else -%}
             {%- assign default_methods = "UPI,GPay,PhonePe,Paytm,COD,VISA" | split: ',' -%}
             {%- for icon in default_methods -%}
               <span class="payment-badge">{{ icon }}</span>
             {%- endfor -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

<script>
  window.addEventListener('DOMContentLoaded', () => {
    const accordions = document.querySelectorAll('.footer__accordion');
    
    const handleResize = () => {
      const isDesktop = window.innerWidth >= 768;
      accordions.forEach(acc => {
        if (isDesktop) {
          acc.setAttribute('open', '');
        } else {
          acc.removeAttribute('open');
        }
      });
    };

    window.addEventListener('resize', handleResize);
    handleResize();
  });
</script>

