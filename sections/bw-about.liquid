<style>
  .bliss-about {
    
    
    font-family: var(--font-body-family);
  }

  /* Hero */
  .bliss-about__hero {
    position: relative;
    min-height: 420px;
    
    display: flex; align-items: center; justify-content: center;
    overflow: hidden; text-align: center; padding: 80px 24px;
    border-bottom: 1px solid rgba(var(--color-foreground),0.07);
  }
  .bliss-about__hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse 70% 60% at 50% 110%, rgba(var(--color-button),0.06) 0%, transparent 70%),
                radial-gradient(ellipse 40% 35% at 85% 10%, rgba(var(--color-button),0.04) 0%, transparent 60%);
    pointer-events: none;
  }
  .bliss-about__eyebrow {
    display: inline-flex; align-items: center; gap: 12px;
    font-size: 10px; font-weight: 700; letter-spacing: 0.22em;
    text-transform: uppercase; color: rgb(var(--color-button)); margin-bottom: 22px;
  }
  .bliss-about__eyebrow::before, .bliss-about__eyebrow::after {
    content: ''; display: inline-block; width: 44px; height: 1px;
    background: rgb(var(--color-button)); opacity: 0.35;
  }
  .bliss-about__hero-title {
    font-family: var(--font-heading-family);
    font-size: calc(var(--font-heading-scale) * 4.25rem); font-weight: 600;
    line-height: 1.1;  margin: 0 0 18px;
    position: relative; z-index: 1;
  }
  .bliss-about__hero-title em, span { background-image: var(--fancy-gradient); -webkit-background-clip: text; color: transparent; font-style: italic; }
  .bliss-about__hero-sub {
    font-size: 16px; line-height: 1.75; 
    max-width: 540px; margin: 0 auto; position: relative; z-index: 1;
  }

  /* Body */
  .bliss-about__body { max-width: 860px; margin: 0 auto; padding: 88px 40px 108px; }
  .bliss-about__block { margin-bottom: 76px; }
  .bliss-about__block:last-child { margin-bottom: 0; }

  .bliss-about__label {
    font-size: 10px; font-weight: 700; letter-spacing: 0.2em;
    text-transform: uppercase; color: rgb(var(--color-button));
    display: flex; align-items: center; gap: 10px; margin-bottom: 14px;
  }
  .bliss-about__label::before {
    content: ''; display: inline-block; width: 28px; height: 1.5px;
    background: linear-gradient(90deg, rgb(var(--color-button)), transparent);
  }
  .bliss-about__block h2 {
    font-family: var(--font-heading-family);
    font-size: calc(var(--font-heading-scale) * 2.625rem); font-weight: 500;
    line-height: 1.18;  margin: 0 0 22px;
  }
  .bliss-about__block h2 em, span { background-image: var(--fancy-gradient); -webkit-background-clip: text; color: transparent; font-style: italic; }
  .bliss-about__block p {
    font-size: 16px; line-height: 1.88;  margin: 0 0 18px;
  }
  .bliss-about__block p:last-of-type { margin-bottom: 0; }

  /* Pull quote */
  .bliss-about__pull {
    border-left: 2px solid rgb(var(--color-button)); padding: 18px 28px;
    margin: 36px 0; background: rgba(var(--color-button),0.04);
    border-radius: 0 8px 8px 0;
  }
  .bliss-about__pull p {
    font-family: var(--font-heading-family);
    font-size: calc(var(--font-heading-scale) * 1.4375rem); font-style: italic;
    color: rgb(var(--color-foreground)) !important; margin: 0 !important;
    line-height: 1.65;
  }

  /* Divider */
  .bliss-about__divider {
    height: 1px; margin: 70px 0;
    background: linear-gradient(90deg, transparent, rgba(var(--color-button),0.18), transparent);
  }

  /* Pillars */
  .bliss-about__pillars {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; margin-top: 48px;
  }
  .bliss-about__pillar {
     border: 1px solid rgba(var(--color-foreground),0.08);
    border-radius: 14px; padding: 26px 22px;
    transition: border-color 250ms ease, box-shadow 250ms ease;
  }
  .bliss-about__pillar:hover {
    border-color: rgba(var(--color-button),0.25);
    box-shadow: 0 4px 20px rgba(var(--color-button),0.08);
  }
  .bliss-about__pillar-icon {
    width: 38px; height: 38px; border-radius: 9px;
    background: rgba(var(--color-button),0.07); border: 1px solid rgba(var(--color-button),0.15);
    display: flex; align-items: center; justify-content: center; margin-bottom: 14px;
  }
  .bliss-about__pillar-icon svg {
    width: 17px; height: 17px; stroke: rgb(var(--color-button));
    fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round;
  }
  .bliss-about__pillar-title {
    font-size: 13px; font-weight: 700;  margin-bottom: 6px;
  }
  .bliss-about__pillar-text {
    font-size: 12px; line-height: 1.7; 
  }

  /* CTAs */
  .bliss-about__cta { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; margin-top: 8px; }
  .bliss-about__btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 14px 28px; font-size: 11px; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    text-decoration: none; border-radius: 7px; transition: all 180ms ease;
  }
  .bliss-about__btn--primary { background: rgb(var(--color-button)); color: rgb(var(--color-button-text)); }
  .bliss-about__btn--primary:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(var(--color-button),0.28); }
  .bliss-about__btn--ghost { color: rgb(var(--color-button)); border: 1px solid rgba(var(--color-button),0.3); }
  .bliss-about__btn--ghost:hover { border-color: rgb(var(--color-button)); background: rgba(var(--color-button),0.06); }

  @media (max-width: 768px) {
    .bliss-about__hero { min-height: 300px; padding: 64px 20px; }
    .bliss-about__body { padding: 56px 20px 72px; }
    .bliss-about__pillars { grid-template-columns: 1fr; }
  }
</style>

<div class="bliss-about color-{{ section.settings.color_scheme }} gradient">
  <div class="bliss-about__hero">
    <div style="position:relative;z-index:1">
      <div class="bliss-about__eyebrow">{{ section.settings.eyebrow }}</div>
      <h1 class="bliss-about__hero-title">{{ section.settings.hero_title }}</h1>
      <p class="bliss-about__hero-sub">{{ section.settings.hero_sub }}</p>
    </div>
  </div>

  <div class="bliss-about__body">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'content_block' -%}
          <div class="bliss-about__block" {{ block.shopify_attributes }}>
            <div class="bliss-about__label">{{ block.settings.label }}</div>
            <h2>{{ block.settings.heading }}</h2>
            <div class="bliss-about__text">
              {{ block.settings.text }}
            </div>
            {%- if block.settings.quote != blank -%}
              <div class="bliss-about__pull">
                <p>{{ block.settings.quote }}</p>
              </div>
            {%- endif -%}
          </div>
        {%- when 'divider' -%}
          <div class="bliss-about__divider" {{ block.shopify_attributes }}></div>
        {%- when 'pillars' -%}
          <div class="bliss-about__pillars" {{ block.shopify_attributes }}>
            <div class="bliss-about__pillar">
              <div class="bliss-about__pillar-icon">
                <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
              </div>
              <div class="bliss-about__pillar-title">{{ block.settings.p1_title }}</div>
              <div class="bliss-about__pillar-text">{{ block.settings.p1_text }}</div>
            </div>
            <div class="bliss-about__pillar">
              <div class="bliss-about__pillar-icon">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              </div>
              <div class="bliss-about__pillar-title">{{ block.settings.p2_title }}</div>
              <div class="bliss-about__pillar-text">{{ block.settings.p2_text }}</div>
            </div>
            <div class="bliss-about__pillar">
              <div class="bliss-about__pillar-icon">
                <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
              </div>
              <div class="bliss-about__pillar-title">{{ block.settings.p3_title }}</div>
              <div class="bliss-about__pillar-text">{{ block.settings.p3_text }}</div>
            </div>
          </div>
        {%- when 'ctas' -%}
          <div class="bliss-about__cta" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link1 }}" class="bliss-about__btn bliss-about__btn--primary">{{ block.settings.label1 }}</a>
            <a href="{{ block.settings.link2 }}" class="bliss-about__btn bliss-about__btn--ghost">{{ block.settings.label2 }}</a>
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "BW About Us",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Story"
    },
    {
      "type": "inline_richtext",
      "id": "hero_title",
      "label": "Hero Title",
      "default": "Born in India."
    },
    {
      "type": "text",
      "id": "hero_sub",
      "label": "Hero Subtext",
      "default": "We didn't set out to build a store."
    }
  ],
  "blocks": [
    {
      "type": "content_block",
      "name": "Content Block",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "How it began" },
        { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Fourteen years in the air." },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Content goes here...</p>" },
        { "type": "text", "id": "quote", "label": "Pull Quote" }
      ]
    },
    {
      "type": "divider",
      "name": "Divider",
      "settings": []
    },
    {
      "type": "pillars",
      "name": "Pillars",
      "settings": [
        { "type": "text", "id": "p1_title", "label": "Pillar 1 Title", "default": "Every product tested" },
        { "type": "text", "id": "p1_text", "label": "Pillar 1 Text", "default": "Minimum 14 days of daily use before anything is listed." },
        { "type": "text", "id": "p2_title", "label": "Pillar 2 Title", "default": "Ships within 24 hours" },
        { "type": "text", "id": "p2_text", "label": "Pillar 2 Text", "default": "Orders placed before 3 PM ship same day." },
        { "type": "text", "id": "p3_title", "label": "Pillar 3 Title", "default": "People, not bots" },
        { "type": "text", "id": "p3_text", "label": "Pillar 3 Text", "default": "Our support team knows every product." }
      ]
    },
    {
      "type": "ctas",
      "name": "CTAs",
      "settings": [
        { "type": "text", "id": "label1", "label": "Button 1 Label", "default": "Explore" },
        { "type": "url", "id": "link1", "label": "Button 1 Link" },
        { "type": "text", "id": "label2", "label": "Button 2 Label", "default": "Contact" },
        { "type": "url", "id": "link2", "label": "Button 2 Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BW About Us"
    }
  ]
}
{% endschema %}