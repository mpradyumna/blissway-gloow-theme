{%- style -%}
  .bw-highlight {
    padding: 80px 0;
    background: var(--bw-surface);
  }

  .bw-highlight-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }

  @media (min-width: 992px) {
    .bw-highlight-grid {
      grid-template-columns: 1fr 1fr;
      gap: 80px;
    }
  }

  .bw-highlight-media img {
    width: 100%;
    height: auto;
    border-radius: 24px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.06);
    display: block;
  }

  .bw-highlight-content {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .bw-highlight-reviews {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    color: var(--bw-text);
    font-size: 0.95rem;
  }

  .bw-highlight-reviews svg {
    color: #F59E0B;
    width: 18px;
    height: 18px;
  }

  .bw-highlight-title {
    font-family: var(--bw-font-display);
    font-size: calc(var(--font-heading-scale) * 3rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--bw-text);
    margin: 0;
  }

  .bw-highlight-bullets {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin: 10px 0;
  }

  .bw-highlight-bullet {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
    
    color: var(--bw-text);
  }

  .bw-highlight-bullet-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--bw-primary-lt);
    color: var(--bw-primary);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .bw-highlight-text {
    
    line-height: 1.6;
    color: var(--bw-text-2);
    margin: 0;
  }

  .bw-highlight-guarantee {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--bw-text-2);
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
  }

  .bw-highlight-scarcity {
    font-size: 0.95rem;
    font-weight: 700;
    color: #DC2626;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: #FEF2F2;
    border-radius: 8px;
    margin-top: 10px;
    width: max-content;
  }
{%- endstyle -%}

<section class="bw-highlight color-{{ section.settings.color_scheme }} gradient" data-aos="fade-up">
  <div class="bw-container">
    <div class="bw-highlight-grid">
      <div class="bw-highlight-media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="bw-highlight-content">
        {%- if section.settings.show_reviews -%}
          <div class="bw-highlight-reviews">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- endfor -%}
            {{ section.settings.reviews_text }}
          </div>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="bw-highlight-title">{{ section.settings.title }}</h2>
        {%- endif -%}

        <div class="bw-highlight-bullets">
          {%- for block in section.blocks -%}
            {%- if block.type == 'bullet' -%}
              <div class="bw-highlight-bullet" {{ block.shopify_attributes }}>
                <div class="bw-highlight-bullet-icon">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                {{ block.settings.text }}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.text != blank -%}
          <p class="bw-highlight-text">{{ section.settings.text }}</p>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="bw-btn bw-btn-primary" style="width: fit-content;">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}

        {%- if section.settings.guarantee_text != blank -%}
          <div class="bw-highlight-guarantee">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {{ section.settings.guarantee_text }}
          </div>
        {%- endif -%}

        {%- if section.settings.scarcity_text != blank -%}
          <div class="bw-highlight-scarcity">
            <span>🚨</span> {{ section.settings.scarcity_text }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "BW - Product Highlight",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "scheme-1" },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    },
    {
      "type": "checkbox",
      "id": "show_reviews",
      "label": "Show Reviews",
      "default": true
    },
    {
      "type": "text",
      "id": "reviews_text",
      "label": "Reviews Text",
      "default": "4000+ Reviews"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Your Go-To for Style and Performance"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Body Text",
      "default": "Enjoy the perfect balance of aesthetics and functionality. The AirLuxe fan blends seamlessly into modern Indian homes while providing unmatched cooling."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "GET YOURS NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee Text",
      "default": "30-Day satisfaction guarantee"
    },
    {
      "type": "text",
      "id": "scarcity_text",
      "label": "Scarcity Text",
      "default": "Head’s up, we’re low on stock!"
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet Point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Bullet Text",
          "default": "Bladeless Safety"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BW - Product Highlight",
      "blocks": [
        { "type": "bullet", "settings": { "text": "Bladeless Safety" } },
        { "type": "bullet", "settings": { "text": "Whisper Quiet (< 40dB)" } },
        { "type": "bullet", "settings": { "text": "HEPA H13 Purified" } }
      ]
    }
  ]
}
{% endschema %}