{%- liquid
  assign lk_images = product.metafields.custom.lookbook_images.value
  assign lk_tags   = product.metafields.custom.lookbook_caption_tags.value
  assign lk_texts  = product.metafields.custom.lookbook_caption_texts.value
-%}

{%- if lk_images != blank and lk_images.size > 0 or request.design_mode -%}

<style>
  #bw-lookbook-{{ section.id }} {
    --lk-bg:        #F4F5F7;
    --lk-blue:      #2563EB;
    --lk-blue-dim:  #1D4ED8;
    --lk-blue-glow: rgba(37,99,235,0.35);
    --lk-ink:       #1D1D1D;
    --lk-ink-mid:   #4B5563;
    --lk-ink-soft:  #9CA3AF;
    --lk-scan:      rgba(37,99,235,0.06);
    padding: var(--section-padding-top, 60px) 0 var(--section-padding-bottom, 60px);
    background: var(--lk-bg);
  }

  #bw-lookbook-{{ section.id }} .bw-lk-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Header ─────────────────────────────────────── */
  #bw-lookbook-{{ section.id }} .bw-lk-header {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 36px;
  }

  #bw-lookbook-{{ section.id }} .bw-lk-label {
    font-family: var(--font-body-family, 'Exo 2', sans-serif);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--lk-blue);
  }

  #bw-lookbook-{{ section.id }} .bw-lk-title {
    font-family: var(--font-heading-family, 'Orbitron', sans-serif);
    font-size: clamp(22px, 3vw, 36px);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--lk-ink);
    line-height: 1;
    margin: 0;
  }

  #bw-lookbook-{{ section.id }} .bw-lk-title .bracket {
    color: var(--lk-blue);
    font-weight: 400;
  }

  #bw-lookbook-{{ section.id }} .bw-lk-subtitle {
    margin-left: auto;
    font-family: var(--font-body-family, 'Exo 2', sans-serif);
    font-size: 12px;
    font-weight: 300;
    letter-spacing: 0.08em;
    color: var(--lk-ink-mid);
    font-style: italic;
    align-self: center;
  }

  /* ── Rule ──────────────────────────────────────── */
  #bw-lookbook-{{ section.id }} .bw-lk-rule {
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, var(--lk-blue) 0%, transparent 60%);
    margin-bottom: 28px;
    opacity: 0.4;
    border: none;
  }

  /* ── Grids ─────────────────────────────────────── */
  #bw-lookbook-{{ section.id }} .bw-lk-grid-primary {
    display: grid;
    grid-template-columns: 3fr 2fr;
    grid-template-rows: auto auto;
    gap: 3px;
    margin-bottom: 3px;
  }

  #bw-lookbook-{{ section.id }} .bw-lk-grid-secondary {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3px;
  }

  /* ── Card base ─────────────────────────────────── */
  #bw-lookbook-{{ section.id }} .bw-lk-card {
    position: relative;
    overflow: hidden;
    background: #1a1a2e;
    cursor: pointer;
  }

  #bw-lookbook-{{ section.id }} .bw-lk-card--hero     { grid-row: span 2; min-height: 480px; }
  #bw-lookbook-{{ section.id }} .bw-lk-card--portrait { aspect-ratio: 4/3; }
  #bw-lookbook-{{ section.id }} .bw-lk-card--square   { aspect-ratio: 1/1; }

  #bw-lookbook-{{ section.id }} .bw-lk-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.25,0.46,0.45,0.94), filter 0.5s ease;
    filter: brightness(0.92) saturate(1.05);
  }

  /* Scan-line overlay */
  #bw-lookbook-{{ section.id }} .bw-lk-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg, transparent, transparent 3px,
      var(--lk-scan) 3px, var(--lk-scan) 4px
    );
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  /* Blue glow border */
  #bw-lookbook-{{ section.id }} .bw-lk-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border: 2px solid var(--lk-blue);
    box-shadow: inset 0 0 40px var(--lk-blue-glow), 0 0 30px var(--lk-blue-glow);
    z-index: 3;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  #bw-lookbook-{{ section.id }} .bw-lk-card:hover::before { opacity: 1; }
  #bw-lookbook-{{ section.id }} .bw-lk-card:hover::after  { opacity: 1; }
  #bw-lookbook-{{ section.id }} .bw-lk-card:hover img {
    transform: scale(1.04);
    filter: brightness(0.7) saturate(1.15);
  }

  /* ── Caption ───────────────────────────────────── */
  #bw-lookbook-{{ section.id }} .bw-lk-caption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 40px 20px 18px;
    background: linear-gradient(to top, rgba(10,10,20,0.88) 0%, transparent 100%);
    z-index: 4;
    transform: translateY(12px);
    opacity: 0;
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  #bw-lookbook-{{ section.id }} .bw-lk-card:hover .bw-lk-caption {
    opacity: 1;
    transform: translateY(0);
  }

  #bw-lookbook-{{ section.id }} .bw-lk-caption-tag {
    font-family: var(--font-heading-family, 'Orbitron', sans-serif);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--lk-blue);
    margin-bottom: 4px;
    display: block;
  }

  #bw-lookbook-{{ section.id }} .bw-lk-caption-text {
    font-family: var(--font-body-family, 'Exo 2', sans-serif);
    font-size: 13px;
    font-weight: 300;
    color: rgba(255,255,255,0.9);
    letter-spacing: 0.03em;
  }

  /* ── Corner bracket ────────────────────────────── */
  #bw-lookbook-{{ section.id }} .bw-lk-corner {
    position: absolute;
    top: 12px; right: 12px;
    z-index: 5;
    width: 20px; height: 20px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease 0.1s;
  }

  #bw-lookbook-{{ section.id }} .bw-lk-corner::before,
  #bw-lookbook-{{ section.id }} .bw-lk-corner::after {
    content: '';
    position: absolute;
    background: var(--lk-blue);
  }
  #bw-lookbook-{{ section.id }} .bw-lk-corner::before { top: 0; right: 0; width: 2px; height: 12px; }
  #bw-lookbook-{{ section.id }} .bw-lk-corner::after  { top: 0; right: 0; width: 12px; height: 2px; }
  #bw-lookbook-{{ section.id }} .bw-lk-card:hover .bw-lk-corner { opacity: 1; }

  /* ── Index number ──────────────────────────────── */
  #bw-lookbook-{{ section.id }} .bw-lk-index {
    position: absolute;
    top: 12px; left: 14px;
    font-family: var(--font-heading-family, 'Orbitron', sans-serif);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.35);
    z-index: 5;
    transition: color 0.3s ease;
  }
  #bw-lookbook-{{ section.id }} .bw-lk-card:hover .bw-lk-index { color: var(--lk-blue); }

  /* ── Footer ────────────────────────────────────── */
  #bw-lookbook-{{ section.id }} .bw-lk-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 28px;
    padding-top: 20px;
    border-top: 1px solid rgba(37,99,235,0.12);
  }

  #bw-lookbook-{{ section.id }} .bw-lk-count {
    font-family: var(--font-body-family, 'Exo 2', sans-serif);
    font-size: 12px;
    font-weight: 300;
    color: var(--lk-ink-soft);
    letter-spacing: 0.06em;
  }
  #bw-lookbook-{{ section.id }} .bw-lk-count strong {
    font-weight: 600;
    color: var(--lk-ink);
  }

  #bw-lookbook-{{ section.id }} .bw-lk-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-heading-family, 'Orbitron', sans-serif);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--lk-blue);
    text-decoration: none;
    padding: 10px 22px;
    border: 1px solid var(--lk-blue);
    position: relative;
    overflow: hidden;
    transition: color 0.3s ease;
  }

  #bw-lookbook-{{ section.id }} .bw-lk-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--lk-blue);
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.25,0.46,0.45,0.94);
  }

  #bw-lookbook-{{ section.id }} .bw-lk-cta:hover { color: #fff; }
  #bw-lookbook-{{ section.id }} .bw-lk-cta:hover::before { transform: translateX(0); }
  #bw-lookbook-{{ section.id }} .bw-lk-cta span { position: relative; z-index: 1; }

  #bw-lookbook-{{ section.id }} .bw-lk-arrow {
    position: relative;
    z-index: 1;
    width: 16px;
    height: 1px;
    background: currentColor;
    display: inline-block;
    transition: width 0.2s ease;
  }
  #bw-lookbook-{{ section.id }} .bw-lk-arrow::after {
    content: '';
    position: absolute;
    right: 0; top: -3px;
    width: 6px; height: 6px;
    border-top: 1px solid currentColor;
    border-right: 1px solid currentColor;
    transform: rotate(45deg);
  }
  #bw-lookbook-{{ section.id }} .bw-lk-cta:hover .bw-lk-arrow { width: 22px; }

  /* ── Mobile ────────────────────────────────────── */
  @media (max-width: 768px) {
    #bw-lookbook-{{ section.id }} .bw-lk-grid-primary {
      grid-template-columns: 1fr 1fr;
    }
    #bw-lookbook-{{ section.id }} .bw-lk-card--hero {
      grid-row: span 1;
      aspect-ratio: 4/3;
      min-height: unset;
    }
    #bw-lookbook-{{ section.id }} .bw-lk-grid-secondary {
      grid-template-columns: 1fr 1fr;
    }
    #bw-lookbook-{{ section.id }} .bw-lk-grid-secondary .bw-lk-card:last-child {
      grid-column: span 2;
      aspect-ratio: 16/7;
    }
    #bw-lookbook-{{ section.id }} .bw-lk-subtitle { display: none; }
    #bw-lookbook-{{ section.id }} .bw-lk-footer { flex-direction: column; gap: 16px; align-items: flex-start; }
  }

  @media (max-width: 480px) {
    #bw-lookbook-{{ section.id }} .bw-lk-grid-primary  { grid-template-columns: 1fr; }
    #bw-lookbook-{{ section.id }} .bw-lk-grid-secondary { grid-template-columns: 1fr 1fr; }
    #bw-lookbook-{{ section.id }} .bw-lk-card--hero,
    #bw-lookbook-{{ section.id }} .bw-lk-card--portrait { aspect-ratio: 4/3; }
  }
</style>

<section id="bw-lookbook-{{ section.id }}" class="bw-product-lookbook">
  <div class="bw-lk-inner">

    {%- comment -%} ── Header ─────────────────────────────── {%- endcomment -%}
    <div class="bw-lk-header">
      {%- if section.settings.section_label != blank -%}
        <span class="bw-lk-label">{{ section.settings.section_label }}</span>
      {%- endif -%}

      <h2 class="bw-lk-title">
        <span class="bracket">[</span>&nbsp;{{ section.settings.heading | upcase }}&nbsp;<span class="bracket">]</span>
      </h2>

      {%- if section.settings.subtitle != blank -%}
        <span class="bw-lk-subtitle">{{ product.title }} — {{ section.settings.subtitle }}</span>
      {%- endif -%}
    </div>

    <hr class="bw-lk-rule">

    {%- comment -%} ── Primary grid: images 0–2 ──────────── {%- endcomment -%}
    {%- if lk_images == blank or lk_images.size == 0 -%}
      <div class="bw-lk-editor-notice" style="padding:40px;text-align:center;color:#9CA3AF;font-size:14px;border:2px dashed #e2e8f0;border-radius:8px;">
        Lookbook images will appear here once the <strong>lookbook.images</strong> product metafield is populated.
      </div>
    {%- else -%}
    <div class="bw-lk-grid-primary">
      {%- for image in lk_images limit: 3 -%}
        {%- liquid
          assign card_class = 'bw-lk-card--portrait'
          if forloop.index0 == 0
            assign card_class = 'bw-lk-card--hero'
          endif
          assign pad_index = forloop.index | prepend: '0' | slice: -2, 2
          assign caption_tag  = lk_tags[forloop.index0]
          assign caption_text = lk_texts[forloop.index0]
        -%}

        <div class="bw-lk-card {{ card_class }}">
          <span class="bw-lk-index">{{ pad_index }}</span>
          <div class="bw-lk-corner"></div>

          {{
            image
            | image_url: width: 900
            | image_tag:
              loading: 'lazy',
              widths: '400, 600, 900',
              alt: caption_text | default: product.title
          }}

          {%- if caption_tag != blank or caption_text != blank -%}
            <div class="bw-lk-caption">
              {%- if caption_tag != blank -%}
                <span class="bw-lk-caption-tag">{{ caption_tag }}</span>
              {%- endif -%}
              {%- if caption_text != blank -%}
                <div class="bw-lk-caption-text">{{ caption_text }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>{%- comment -%} /bw-lk-grid-primary {%- endcomment -%}

    {%- comment -%} ── Secondary grid: images 3–5 ────────── {%- endcomment -%}
    {%- if lk_images.size > 3 -%}
      <div class="bw-lk-grid-secondary">
        {%- for image in lk_images limit: 3 offset: 3 -%}
          {%- liquid
            assign actual_idx   = forloop.index0 | plus: 3
            assign pad_index    = actual_idx | plus: 1 | prepend: '0' | slice: -2, 2
            assign caption_tag  = lk_tags[actual_idx]
            assign caption_text = lk_texts[actual_idx]
          -%}

          <div class="bw-lk-card bw-lk-card--square">
            <span class="bw-lk-index">{{ pad_index }}</span>
            <div class="bw-lk-corner"></div>

            {{
              image
              | image_url: width: 600
              | image_tag:
                loading: 'lazy',
                widths: '300, 450, 600',
                alt: caption_text | default: product.title
            }}

            {%- if caption_tag != blank or caption_text != blank -%}
              <div class="bw-lk-caption">
                {%- if caption_tag != blank -%}
                  <span class="bw-lk-caption-tag">{{ caption_tag }}</span>
                {%- endif -%}
                {%- if caption_text != blank -%}
                  <div class="bw-lk-caption-text">{{ caption_text }}</div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ── Footer ─────────────────────────────── {%- endcomment -%}
    <div class="bw-lk-footer">
      <span class="bw-lk-count">
        Showing <strong>{{ lk_images.size | at_most: 6 }}</strong> of {{ lk_images.size }} shots
      </span>

      {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
        <a href="{{ section.settings.cta_url }}" class="bw-lk-cta">
          <span>{{ section.settings.cta_label }}</span>
          <span class="bw-lk-arrow"></span>
        </a>
      {%- endif -%}
    </div>

    {%- endif -%}{%- comment -%} /lk_images blank check {%- endcomment -%}

  </div>
</section>

{%- endif -%}

{% schema %}
{
  "name": "BW Product Lookbook",
  "tag": "div",
  "class": "bw-product-lookbook-wrapper",
  "limit": 1,
  "settings": [
    {
      "type": "paragraph",
      "content": "Images, caption tags, and caption texts are pulled from the product metafields: `lookbook.images`, `lookbook.caption_tags`, `lookbook.caption_texts`."
    },
    {
      "type": "text",
      "id": "section_label",
      "label": "Section label",
      "default": "Visual Story",
      "info": "Small uppercase label above the title"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "LOOKBOOK"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "In the Wild",
      "info": "Appended after the product title e.g. \"EarPods Pro X — In the Wild\""
    },
    {
      "type": "header",
      "content": "CTA Button"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "View Full Lookbook"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "BW Product Lookbook"
    }
  ]
}
{% endschema %}
