{%- comment -%}
  BW Waist Fan — Conversion PDP Section
  Target: India, Paid Traffic (Meta/Google)
  Goal: Handle objections, build trust, drive Add-to-Cart
  Sections: Trust → Pain Hook → How It Works → Use Cases → Stats → Comparison → Reviews → FAQ → Guarantee → CTA
{%- endcomment -%}

<style>
  /* ── Local tokens (extend BW system) ── */
  .wf-pdp {
    --wf-bg:       var(--bw-bg, #F5F5F5);
    --wf-surface:  var(--bw-surface, #FFFFFF);
    --wf-text:     var(--bw-text, #1D1D1D);
    --wf-muted:    var(--bw-text-muted, rgba(29,29,29,.52));
    --wf-blue:     var(--bw-primary, #2563EB);
    --wf-blue-dk:  var(--bw-primary-dk, #1D4ED8);
    --wf-blue-lt:  var(--bw-primary-lt, rgba(37,99,235,.08));
    --wf-border:   var(--bw-border, rgba(29,29,29,.08));
    --wf-dark:     #07090E;
    --wf-radius:   var(--bw-radius, 12px);
    --wf-radius-lg:var(--bw-radius-lg, 20px);
    font-family: var(--bw-font-body, var(--font-body-family));
  }

  /* ── Shared utilities ── */
  .wf-section      { padding: 64px 20px; background: var(--wf-bg); }
  .wf-section--white { background: var(--wf-surface); }
  .wf-section--dark  { background: var(--wf-dark); }
  .wf-container    { max-width: 1120px; margin: 0 auto; }
  .wf-center       { text-align: center; }
  .wf-eyebrow {
    display: inline-block;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--wf-blue);
    margin-bottom: 10px;
  }
  .wf-eyebrow--light { color: #93C5FD; }
  .wf-h2 {
    font-family: var(--bw-font-display, var(--font-heading-family));
    font-size: clamp(2.2rem, 4.5vw, 3.6rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--wf-text);
    margin: 0 0 14px;
  }
  .wf-h2--white { color: #fff; }
  .wf-sub {
    font-size: clamp(1.4rem, 2vw, 1.6rem);
    line-height: 1.65;
    color: var(--wf-muted);
    max-width: 580px;
    margin: 0 0 40px;
  }
  .wf-sub--white { color: rgba(255,255,255,.65); }
  .wf-center .wf-sub { margin-inline: auto; }

  /* ── TRUST BAR ── */
  .wf-trust {
    background: var(--wf-dark);
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .wf-trust__item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    font-weight: 600;
    color: rgba(255,255,255,.88);
    letter-spacing: .03em;
    padding: 11px 14px;
    border-bottom: 1px solid rgba(255,255,255,.07);
  }
  .wf-trust__item:last-child {
    border-bottom: none;
  }
  .wf-trust__item svg {
    width: 22px; height: 22px;
    color: var(--wf-blue);
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .wf-trust {
      flex-direction: row;
      flex-wrap: nowrap;
      justify-content: center;
      align-items: stretch;
      padding: 0;
    }
    .wf-trust__item {
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 8px;
      text-align: center;
      font-size: 12px;
      padding: 18px 28px;
      border-bottom: none;
      border-right: 1px solid rgba(255,255,255,.1);
      white-space: nowrap;
      flex: 1;
    }
    .wf-trust__item:last-child {
      border-right: none;
    }
    .wf-trust__item svg {
      width: 26px; height: 26px;
    }
  }

  /* ── PAIN HOOK ── */
  .wf-pain {
    padding: 56px 20px;
    background: var(--wf-dark);
    border-top: 1px solid rgba(37,99,235,.2);
  }
  .wf-pain__inner {
    max-width: 780px;
    margin: 0 auto;
    text-align: center;
  }
  .wf-pain__headline {
    font-family: var(--bw-font-display, var(--font-heading-family));
    font-size: clamp(2.4rem, 5vw, 4rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.15;
    margin: 0 0 16px;
  }
  .wf-pain__headline em {
    font-style: normal;
    color: var(--wf-blue);
  }
  .wf-pain__sub {
    font-size: clamp(1.4rem, 2vw, 1.7rem);
    color: rgba(255,255,255,.6);
    line-height: 1.6;
    margin: 0;
  }
  .wf-pain__divider {
    width: 48px;
    height: 3px;
    background: var(--wf-blue);
    margin: 20px auto 0;
    border-radius: 2px;
  }

  /* ── HOW IT WORKS ── */
  .wf-hiw__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  @media (min-width: 768px) {
    .wf-hiw__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .wf-hiw__card {
    background: var(--wf-surface);
    border: 1px solid var(--wf-border);
    border-radius: var(--wf-radius-lg);
    padding: 32px 24px;
    position: relative;
  }
  .wf-hiw__num {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: var(--wf-blue-lt);
    border: 2px solid var(--wf-blue);
    color: var(--wf-blue);
    font-size: 16px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 18px;
  }
  .wf-hiw__icon { display: flex; align-items: center; margin-bottom: 12px; color: var(--wf-blue); }
  .wf-hiw__icon svg { width: 34px; height: 34px; flex-shrink: 0; }
  .wf-hiw__title { font-size: 16px; font-weight: 700; margin: 0 0 8px; color: var(--wf-text); }
  .wf-hiw__text  { font-size: 13.5px; line-height: 1.65; color: var(--wf-muted); margin: 0; }

  /* ── PERSONA CARDS ── */
  .wf-persona__scroll {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  .wf-persona__scroll::-webkit-scrollbar { display: none; }
  @media (min-width: 768px) {
    .wf-persona__scroll {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      overflow-x: unset;
      scroll-snap-type: unset;
    }
  }
  .wf-persona__card {
    position: relative;
    border-radius: var(--wf-radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    flex: 0 0 75vw;
    scroll-snap-align: start;
    min-width: 0;
  }
  @media (min-width: 768px) {
    .wf-persona__card { flex: unset; }
  }
  .wf-persona__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .wf-persona__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.78) 0%, rgba(0,0,0,.18) 50%, transparent 100%);
  }
  .wf-persona__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px 20px;
  }
  .wf-persona__label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--wf-blue);
    background: rgba(37,99,235,.18);
    border: 1px solid rgba(37,99,235,.45);
    border-radius: 4px;
    padding: 3px 10px;
    margin-bottom: 10px;
  }
  .wf-persona__headline {
    font-family: var(--bw-font-display, var(--font-heading-family));
    font-size: clamp(1.7rem, 2.4vw, 2.1rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.25;
    margin: 0;
  }

  /* ── PROOF STATS ── */
  .wf-stats__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }
  @media (min-width: 600px) {
    .wf-stats__grid { grid-template-columns: repeat(4, 1fr); }
  }
  .wf-stat {
    text-align: center;
    padding: 24px 16px;
    border-radius: var(--wf-radius);
    border: 1px solid rgba(37,99,235,.25);
    background: rgba(37,99,235,.06);
  }
  .wf-stat__num {
    font-family: var(--bw-font-display, var(--font-heading-family));
    font-size: clamp(2.8rem, 5vw, 3.8rem);
    font-weight: 800;
    color: var(--wf-blue);
    line-height: 1;
    display: block;
    margin-bottom: 8px;
  }
  .wf-stat__label { font-size: 13px; color: rgba(255,255,255,.65); line-height: 1.4; }

  /* ── COMPARISON TABLE ── */
  .wf-compare { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .wf-compare__table {
    width: 100%;
    border-collapse: collapse;
    min-width: 480px;
  }
  .wf-compare__table th,
  .wf-compare__table td {
    padding: 13px 16px;
    text-align: center;
    font-size: 13.5px;
    border-bottom: 1px solid var(--wf-border);
  }
  .wf-compare__table th {
    font-size: 12px;
    font-weight: 700;
    background: var(--wf-bg);
    text-transform: uppercase;
    letter-spacing: .07em;
    color: var(--wf-muted);
  }
  .wf-compare__table th:nth-child(2) {
    background: var(--wf-blue);
    color: #fff;
    border-radius: 10px 10px 0 0;
  }
  .wf-compare__table td:nth-child(2) {
    background: var(--wf-blue-lt);
    font-weight: 600;
  }
  .wf-compare__table td:first-child { text-align: left; font-weight: 600; color: var(--wf-text); }
  .wf-compare__table tr:last-child td { border-bottom: none; }
  .wf-chk  { color: var(--wf-blue); font-weight: 800; font-size: 17px; }
  .wf-cross{ color: #CACACE; font-size: 17px; }
  .wf-part { color: #F59E0B; font-size: 12px; font-weight: 600; }

  /* ── REVIEWS ── */
  .wf-reviews__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 768px) {
    .wf-reviews__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .wf-review {
    background: var(--wf-surface);
    border: 1px solid var(--wf-border);
    border-radius: var(--wf-radius-lg);
    padding: 24px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .wf-review__stars { color: #F59E0B; font-size: 15px; letter-spacing: 2px; }
  .wf-review__badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    background: var(--wf-blue-lt);
    color: var(--wf-blue);
    padding: 3px 8px;
    border-radius: 4px;
  }
  .wf-review__text { font-size: 14px; line-height: 1.65; color: var(--wf-text); margin: 0; flex: 1; }
  .wf-review__author {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: var(--wf-muted);
  }
  .wf-review__author span { color: var(--wf-blue); }

  /* ── FAQ ── */
  .wf-faq__list { max-width: 760px; margin: 0 auto; }
  .wf-faq__item { border-bottom: 1px solid var(--wf-border); }
  .wf-faq__btn {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    background: none;
    border: none;
    font-family: inherit;
    font-size: 15px;
    font-weight: 700;
    color: var(--wf-text);
    cursor: pointer;
    text-align: left;
    gap: 16px;
  }
  .wf-faq__chevron {
    width: 20px; height: 20px;
    flex-shrink: 0;
    transition: transform .3s ease;
    color: var(--wf-blue);
  }
  .wf-faq__item.open .wf-faq__chevron { transform: rotate(180deg); }
  .wf-faq__body {
    max-height: 0;
    overflow: hidden;
    transition: max-height .4s ease, opacity .3s ease;
    opacity: 0;
  }
  .wf-faq__item.open .wf-faq__body { opacity: 1; }
  .wf-faq__body-inner {
    padding-bottom: 18px;
    font-size: 14px;
    line-height: 1.75;
    color: var(--wf-muted);
  }
  .wf-faq__body-inner strong { color: var(--wf-text); }

  /* ── GUARANTEE ── */
  .wf-guarantee {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    max-width: 900px;
    margin: 0 auto;
  }
  @media (min-width: 600px) {
    .wf-guarantee { grid-template-columns: repeat(3, 1fr); }
  }
  .wf-guarantee__card {
    text-align: center;
    padding: 30px 20px;
    background: rgba(37,99,235,.08);
    border: 1px solid rgba(37,99,235,.22);
    border-radius: var(--wf-radius-lg);
  }
  .wf-guarantee__icon { display: flex; align-items: center; justify-content: center; margin-bottom: 12px; color: var(--wf-blue); }
  .wf-guarantee__icon svg { width: 40px; height: 40px; flex-shrink: 0; }
  .wf-guarantee__title { font-size: 16px; font-weight: 700; color: #fff; margin: 0 0 6px; }
  .wf-guarantee__text  { font-size: 13px; color: rgba(255,255,255,.55); line-height: 1.55; margin: 0; }

  /* ── CTA STRIP ── */
  .wf-cta-strip {
    background: var(--wf-blue);
    padding: 56px 20px;
    text-align: center;
  }
  .wf-cta-strip__headline {
    font-family: var(--bw-font-display, var(--font-heading-family));
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 800;
    color: #fff;
    margin: 0 0 10px;
  }
  .wf-cta-strip__sub {
    font-size: 15px;
    color: rgba(255,255,255,.75);
    margin: 0 0 28px;
  }
  .wf-cta-strip__btn {
    display: inline-block;
    background: #fff;
    color: var(--wf-blue);
    font-size: 14px;
    font-weight: 800;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: 16px 44px;
    border-radius: var(--wf-radius);
    text-decoration: none;
    transition: transform .15s ease, box-shadow .15s ease;
  }
  .wf-cta-strip__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(37,99,235,.35);
  }
  .wf-cta-strip__urgency {
    margin-top: 14px;
    font-size: 12px;
    color: rgba(255,255,255,.65);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 6px;
    letter-spacing: .05em;
  }
  .wf-urgency-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .wf-urgency-dot { opacity: .4; }

  /* ── STICKY MOBILE CTA ── */
  .wf-sticky-bar {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 999;
    background: #fff;
    border-top: 1px solid var(--wf-border);
    padding: 12px 16px;
    box-shadow: 0 -4px 20px rgba(0,0,0,.1);
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  @media (max-width: 767px) {
    .wf-sticky-bar { display: flex; }
  }
  .wf-sticky-bar__meta { display: flex; flex-direction: column; gap: 2px; }
  .wf-sticky-bar__name { font-size: 13px; font-weight: 700; color: var(--wf-text); }
  .wf-sticky-bar__price { font-size: 18px; font-weight: 800; color: var(--wf-blue); }
  .wf-sticky-bar__price s { font-size: 12px; color: var(--wf-muted); font-weight: 400; margin-left: 4px; }
  .wf-sticky-bar__btn {
    flex-shrink: 0;
    background: var(--wf-blue);
    color: #fff;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: 13px 22px;
    border-radius: var(--wf-radius);
    text-decoration: none;
    white-space: nowrap;
    transition: background .15s ease;
  }
  .wf-sticky-bar__btn:hover { background: var(--wf-blue-dk); }
</style>

<div class="wf-pdp">

  {%- comment -%} ── USP ICON STRIP ── {%- endcomment -%}
  {% render 'bw-waist-fan-usp' %}

  {%- comment -%} ── TRUST BAR ── {%- endcomment -%}
  <div class="wf-trust">
    <div class="wf-trust__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="5" width="22" height="14" rx="2"/><circle cx="12" cy="12" r="3"/><path d="M1 10h4M19 10h4M1 14h4M19 14h4"/></svg>
      Cash on Delivery Available
    </div>
    <div class="wf-trust__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v4h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      Fast Delivery
    </div>
    <div class="wf-trust__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
      Additional 5% off for pre-paid orders
    </div>
    <div class="wf-trust__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 001 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16v-2"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
      Free Shipping
    </div>
    <div class="wf-trust__item">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
      WhatsApp Support
    </div>
  </div>

  {%- comment -%} ── PAIN HOOK ── {%- endcomment -%}
  <div class="wf-pain">
    <div class="wf-pain__inner">
      <p class="wf-pain__headline">
        India's summers don't wait.<br>
        Neither should <em>your cooling</em>.
      </p>
      <p class="wf-pain__sub">
        When the AC goes down, the power cuts, or you're stuck in a packed DTC bus — the Waist Fan keeps you cool. Hands-free. Everywhere you go.
      </p>
      <div class="wf-pain__divider"></div>
    </div>
  </div>

  {%- comment -%} ── HOW IT WORKS ── {%- endcomment -%}
  <section class="wf-section wf-section--white">
    <div class="wf-container">
      <div class="wf-center">
        <span class="wf-eyebrow">Simple as 1-2-3</span>
        <h2 class="wf-h2">{{ section.settings.hiw_heading | default: 'How the Waist Fan Works' }}</h2>
        <p class="wf-sub">No wires. No complicated setup. Clip it on and step out — cool in seconds.</p>
      </div>
      <div class="wf-hiw__grid">
        <div class="wf-hiw__card">
          <div class="wf-hiw__num">1</div>
          <span class="wf-hiw__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg></span>
          <p class="wf-hiw__title">Clip to Your Waist</p>
          <p class="wf-hiw__text">The magnetic waist clip snaps onto any belt, waistband, or bag strap in under 3 seconds. The 360° adjustable nozzle aims airflow exactly where you need it.</p>
        </div>
        <div class="wf-hiw__card">
          <div class="wf-hiw__num">2</div>
          <span class="wf-hiw__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.59 4.59A2 2 0 1 1 11 8H2m10.59 11.41A2 2 0 1 0 14 16H2m15.73-8.27A2 2 0 1 1 19.73 12H2"/></svg></span>
          <p class="wf-hiw__title">Choose Your Speed</p>
          <p class="wf-hiw__text">One-touch button cycles through 3 turbo speeds. The 15,500 RPM motor delivers real direct airflow — not a gentle breeze, actual cooling you can feel.</p>
        </div>
        <div class="wf-hiw__card">
          <div class="wf-hiw__num">3</div>
          <span class="wf-hiw__icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="2" x2="12" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><polyline points="20 16 16 12 20 8"/><polyline points="4 8 8 12 4 16"/><polyline points="16 4 12 8 8 4"/><polyline points="8 20 12 16 16 20"/></svg></span>
          <p class="wf-hiw__title">Stay Cool, Hands-Free</p>
          <p class="wf-hiw__text">Both hands free. No sweat patches. No neck strain. Works on the bus, at your desk, at a construction site — wherever Indian summers follow you.</p>
        </div>
