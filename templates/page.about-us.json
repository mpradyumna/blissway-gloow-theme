        "our_philosophy": {
          "type": "content_block",
          "settings": {
            "label": "Our philosophy",
            "heading": "We sell less. So you get more.",
            "text": "<p>Blissway carries fewer than 60 products at any given time. That is not a limitation — it is a position. Every item on this site has survived a minimum of two weeks of real-world testing by our team. If we wouldn't give it as a gift, it does not reach your doorstep.</p><p>We work directly with verified manufacturers — most audited in person. No middlemen inflating margins, no generic imports dressed up with packaging. What you see is what was built, and it is priced to reflect that.</p>"
          }
        },
        "pillars": {
