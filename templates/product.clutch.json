        "custom_liquid_U4Ejci": {
          "type": "custom_liquid",
          "disabled": true,
          "settings": {
            "custom_liquid": "<!-- Blissway MagCube — Universal Compatibility Highlight (Premium Style) -->\n<style>\n  .blissway-universal {\n    --accent: #ff7a59;\n    --accent2: #6d28d9;\n    --muted: #6b7280;\n    --bg: linear-gradient(180deg, #ffffff 0%, #f9fafb 100%);\n    font-family: 'Inter', system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial;\n    color: #0f172a;\n    padding: 60px 20px;\n    border-radius: 24px;\n    background: var(--bg);\n    box-shadow: 0 12px 40px rgba(15,23,42,0.08);\n    max-width: 1100px;\n    margin: 50px auto;\n    text-align: center;\n    position: relative;\n    overflow: hidden;\n  }\n\n  /* Decorative background gradient halo */\n  .blissway-universal::before {\n    content: \"\";\n    position: absolute;\n    top: -60px; left: -60px; right: -60px; bottom: -60px;\n    background: radial-gradient(circle at center, rgba(255,122,89,0.15), transparent 70%);\n    z-index: 0;\n  }\n\n  .blissway-universal h2 {\n    font-size: 30px;\n    font-weight: 800;\n    background: linear-gradient(90deg, var(--accent), var(--accent2));\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    margin-bottom: 18px;\n    position: relative;\n    z-index: 1;\n  }\n\n  .blissway-universal p.sub {\n    font-size: 17px;\n    color: var(--muted);\n    margin-bottom: 28px;\n    position: relative;\n    z-index: 1;\n  }\n\n  /* Key tagline cards */\n  .blissway-taglines {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));\n    gap: 18px;\n    margin-bottom: 30px;\n    position: relative;\n    z-index: 1;\n  }\n\n  .blissway-tagline {\n    background: #ffffff;\n    border: 1px solid #f0f0f5;\n    border-radius: 16px;\n    padding: 18px 16px;\n    box-shadow: 0 6px 20px rgba(79,70,229,0.06);\n    transition: transform 0.3s ease, box-shadow 0.3s ease;\n  }\n  .blissway-tagline:hover {\n    transform: translateY(-4px);\n    box-shadow: 0 10px 26px rgba(79,70,229,0.12);\n  }\n  .blissway-tagline strong {\n    display: block;\n    font-size: 15px;\n    font-weight: 700;\n    color: #111827;\n    margin-bottom: 6px;\n  }\n  .blissway-tagline span {\n    font-size: 13px;\n    color: var(--muted);\n  }\n\n  /* Compatibility badges */\n  .compat-badges {\n    display: flex;\n    justify-content: center;\n    flex-wrap: wrap;\n    gap: 10px;\n    margin-top: 20px;\n    position: relative;\n    z-index: 1;\n  }\n  .badge {\n    background: linear-gradient(90deg, #ffffff, #f9fafc);\n    border: 1px solid #e5e7eb;\n    border-radius: 999px;\n    padding: 8px 14px;\n    font-size: 13px;\n    color: #111827;\n    font-weight: 600;\n    box-shadow: 0 4px 10px rgba(15,23,42,0.05);\n  }\n\n  /* Optional highlight glow ring */\n  .glow-ring {\n    position: absolute;\n    top: -80px;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 400px;\n    height: 400px;\n    background: radial-gradient(circle at center, rgba(255,122,89,0.08), transparent 70%);\n    border-radius: 50%;\n    z-index: 0;\n  }\n</style>\n\n<section class=\"blissway-universal\">\n  <div class=\"glow-ring\"></div>\n  <h2>Universal Magnetic Power — For Everyone ⚡</h2>\n  <p class=\"sub\">Not just for iPhone. MagCube powers Samsung, Pixel, OnePlus and every Qi-enabled device — with the same sleek design.</p>\n\n  <div class=\"blissway-taglines\">\n    <div class=\"blissway-tagline\">\n      <strong>Works with iPhone, Samsung, Pixel & More — No Limits.</strong>\n      <span>One charger that unites every device in your setup.</span>\n    </div>\n    <div class=\"blissway-tagline\">\n      <strong>Apple Look, Android Power.</strong>\n      <span>MagSafe-style convenience — now open to everyone.</span>\n    </div>\n    <div class=\"blissway-tagline\">\n      <strong>Magnetic Precision, Universal Fit.</strong>\n      <span>Perfect alignment & fast wireless charging across brands.</span>\n    </div>\n  </div>\n\n  <div class=\"compat-badges\">\n    <div class=\"badge\">iPhone</div>\n    <div class=\"badge\">Samsung</div>\n    <div class=\"badge\">OnePlus</div>\n    <div class=\"badge\">Pixel</div>\n    <div class=\"badge\">AirPods</div>\n    <div class=\"badge\">Galaxy Buds</div>\n    <div class=\"badge\">All Qi Devices</div>\n  </div>\n</section>"
          }
        },
