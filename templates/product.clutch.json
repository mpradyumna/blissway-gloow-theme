    "lumin_review_Bn3WBa": {
      "type": "Lumin-review",
      "blocks": {
        "review_PyC4kh": {
          "type": "review",
          "settings": {
            "selected_product": "",
            "star_rating": 4.5,
            "name_text": "Ananya R., Delhi Age 27",
            "country_code": "US",
            "show_country_flag": true,
            "date_text": "Feb 2026",
            "review_head": " I would buy again",
            "review_text": "The item arrived when promised, and the clutch is actually larger than I thought. Although I knew it was a clutch, and I absolutely love it, it would be great if it had detachable straps in the event I chose to use it in another way or place it don’t want me. But the colors are bright and I definitely got what I paid for.",
            "like_size": 38,
            "dislike_size": 0,
            "feature_font_size": 16
          }
        },
        "review_JWEEwK": {
          "type": "review",
          "settings": {
            "selected_product": "",
            "star_rating": 4,
            "name_text": "anonymous",
            "country_code": "US",
            "show_country_flag": true,
            "date_text": "Feb 2026",
            "review_head": "Nice item",
            "review_text": " It not a large purse it's the right size for date night",
            "like_size": 5,
            "dislike_size": 0,
            "feature_font_size": 16
          }
        },
        "review_rGJP77": {
          "type": "review",
          "settings": {
            "selected_product": "",
            "star_rating": 4.5,
            "name_text": "Honest Mom!",
            "country_code": "US",
            "show_country_flag": true,
            "date_text": "Feb 2026",
            "review_head": "Nice Bag in Tomato Red!",
            "review_text": "This is a darling bag. I ordered the red and it is quite the bang for your buck. I’m very happy with it. The fabric is nice. It is a two toned tomato red. The stitching is even. I wouldn’t call this an evening bag. It doesn’t have a dressy or formal look. I would call this a slouchy day bag. A nice pop of color. I could also see this being used for a knitting project as long as the needles being used are not long.",
            "like_size": 2,
            "dislike_size": 0,
            "feature_font_size": 16
          }
        },
        "review_NDD36j": {
          "type": "review",
          "settings": {
            "selected_product": "",
            "star_rating": 4.5,
            "name_text": "Lisa C.",
            "country_code": "US",
            "show_country_flag": true,
            "date_text": "Feb 2026",
            "review_head": " Very Versitile!",
            "review_text": "really cute! Has a strong open/shut clasp. The fabric quality isn't amazing, but it's good enough. Like how you can dress it up and down. I think I may even use it as a travel bag for accessories or toiletries too! I like how versatile it is!",
            "like_size": 8,
            "dislike_size": 0,
            "feature_font_size": 16
          }
        },
        "review_EbAMPx": {
          "type": "review",
          "settings": {
            "selected_product": "",
            "star_rating": 5,
            "name_text": "Neha M., Bangalore • Age 32",
            "country_code": "US",
            "show_country_flag": true,
            "date_text": "Feb 2026",
            "review_head": "Great value on a fun summer clutch!",
            "review_text": "This is a great summer clutch made of a durable woven fabric that is matte enough not to look cheap. It offer’s a great pop of color at a great price. It holds the essentials when carrying folded over under the arm, or more if you’re holding it by the top — which seems like it would be a little awkward for any length of time so this is not a great purse for a day of shopping but great for brunch. The Red/Yellow is actually Red/Camel and the camel is very classic. The red is this year’s cherry red, it’s bright and unfortunately doesn’t go with the deeper reds I prefer. Will return in favor of the Black/Camel combination.",
            "like_size": 12,
            "dislike_size": 0,
            "feature_font_size": 16
          }
        },
        "review_9QC3tA": {
          "type": "review",
          "settings": {
            "selected_product": "",
            "star_rating": 5,
            "name_text": "Pooja K., Jaipur • Age 35",
            "country_code": "US",
            "show_country_flag": true,
            "date_text": "March 2026",
            "review_head": "High Quality, Vibrant Colors, Perfect Size",
            "review_text": "This bag is very cute, the material is thick and it’s made very well. The colors are vibrant and it is the perfect size! It has plenty of room for all the necessities but not so big that it’s too big. Honestly, the perfect size.",
            "like_size": 7,
            "dislike_size": 0,
            "feature_font_size": 16
          }
        },
        "review_4C6VA9": {
          "type": "review",
          "settings": {
            "selected_product": "",
            "star_rating": 5,
            "name_text": "Ritika S., Pune • Age 24",
            "country_code": "US",
            "show_country_flag": true,
            "date_text": "Jan 2026",
            "review_head": "“Got so many compliments”",
            "review_text": "I absolutely love this bag! The bold pink and green stripes are so vibrant and eye-catching — it adds such a fun pop of color to my outfit or vanity setup. The shape is super unique and stylish, and it’s surprisingly roomy inside. I use it as a makeup bag, but it could easily double as a clutch or travel pouch. The material feels durable and well-made, and it holds its structure nicely. I’ve gotten so many compliments on it already! If you’re looking for something playful but practical, this is a great pick.",
            "like_size": 3,
            "dislike_size": 0,
            "feature_font_size": 16
          }
        }
      },
