    "custom_liquid_t66wxn": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<!-- Extra 10% Off on Prepaid Section - Custom HTML/CSS -->\n<!-- Midnight Luxe Design System -->\n<!-- Place this right below your hero section on homepage -->\n\n<div class=\"blissway-prepaid-incentive\">\n  <div class=\"prepaid-container\">\n    <!-- Left Content -->\n    <div class=\"prepaid-content\">\n      <div class=\"prepaid-badge\">⚡ EXCLUSIVE OFFER</div>\n      <h2 class=\"prepaid-title\">Extra 10% Off on Prepaid</h2>\n      <p class=\"prepaid-description\">Pay via UPI, Cards, or Wallets and unlock instant savings on every order</p>\n      \n      <!-- Payment Methods -->\n      <div class=\"payment-methods\">\n        <div class=\"payment-method\">\n          <svg class=\"payment-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n            <path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z\"/>\n          </svg>\n          <span>UPI</span>\n        </div>\n        <div class=\"payment-method\">\n          <svg class=\"payment-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n            <rect x=\"2\" y=\"4\" width=\"20\" height=\"16\" rx=\"2\" ry=\"2\"/>\n            <line x1=\"2\" y1=\"10\" x2=\"22\" y2=\"10\"/>\n          </svg>\n          <span>Cards</span>\n        </div>\n        <div class=\"payment-method\">\n          <svg class=\"payment-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n            <path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z\"/>\n          </svg>\n          <span>Wallets</span>\n        </div>\n      </div>\n\n      <!-- Savings Highlight -->\n      <div class=\"savings-highlight\">\n        <div class=\"savings-item\">\n          <span class=\"savings-label\">Average Savings</span>\n          <span class=\"savings-amount\">₹499</span>\n        </div>\n        <div class=\"savings-divider\"></div>\n        <div class=\"savings-item\">\n          <span class=\"savings-label\">On ₹4999 Order</span>\n          <span class=\"savings-amount\">10%</span>\n        </div>\n      </div>\n\n      <!-- CTA Button -->\n      <a href=\"/collections/all\" class=\"prepaid-cta\">Shop Now & Save</a>\n    </div>\n\n    <!-- Right Visual -->\n    <div class=\"prepaid-visual\">\n      <div class=\"visual-card\">\n        <div class=\"card-chip\"></div>\n        <div class=\"card-number\">•••• •••• •••• 4242</div>\n        <div class=\"card-holder\">\n          <span class=\"card-label\">CARDHOLDER</span>\n          <span class=\"card-name\">Amit Kumar</span>\n        </div>\n      </div>\n      <div class=\"visual-badge\">\n        <span class=\"badge-text\">SAVE 10%</span>\n        <span class=\"badge-amount\">₹499</span>\n      </div>\n    </div>\n  </div>\n\n  <!-- Trust Line -->\n  <div class=\"prepaid-trust\">\n    <div class=\"trust-line-item\">\n      <svg class=\"trust-line-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n        <path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z\"/>\n      </svg>\n      <span>Secure & Encrypted</span>\n    </div>\n    <div class=\"trust-line-item\">\n      <svg class=\"trust-line-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n        <path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z\"/>\n      </svg>\n      <span>Instant Discount Applied</span>\n    </div>\n    <div class=\"trust-line-item\">\n      <svg class=\"trust-line-icon\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n        <path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z\"/>\n      </svg>\n      <span>No Code Required</span>\n    </div>\n  </div>\n</div>\n\n<style>\n  /* Midnight Luxe Color Palette */\n  :root {\n    --color-bg: #0F0F14;\n    --color-surface: #1A1A22;\n    --color-text-primary: #F0EDE8;\n    --color-text-secondary: #8A8A95;\n    --color-accent: #00D4AA;\n    --color-accent-dark: #00A080;\n    --color-gold: #C9A96E;\n    --color-border: rgba(255, 255, 255, 0.08);\n    --color-coral: #FF6B6B;\n  }\n\n  /* Main Container */\n  .blissway-prepaid-incentive {\n    background: linear-gradient(135deg, #1A1A22 0%, #0F0F14 100%);\n    padding: 60px 20px;\n    margin: 0;\n    font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n  }\n\n  .prepaid-container {\n    max-width: 1200px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 60px;\n    align-items: center;\n  }\n\n  /* Left Content */\n  .prepaid-content {\n    display: flex;\n    flex-direction: column;\n    gap: 24px;\n  }\n\n  /* Badge */\n  .prepaid-badge {\n    display: inline-block;\n    background: rgba(255, 107, 107, 0.15);\n    border: 1px solid rgba(255, 107, 107, 0.3);\n    color: var(--color-coral);\n    padding: 8px 16px;\n    border-radius: 24px;\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 0.15em;\n    text-transform: uppercase;\n    width: fit-content;\n  }\n\n  /* Title */\n  .prepaid-title {\n    font-size: clamp(28px, 4vw, 42px);\n    font-weight: 700;\n    color: var(--color-text-primary);\n    margin: 0;\n    letter-spacing: -0.02em;\n    line-height: 1.1;\n  }\n\n  /* Description */\n  .prepaid-description {\n    font-size: 16px;\n    color: var(--color-text-secondary);\n    margin: 0;\n    line-height: 1.6;\n    max-width: 500px;\n  }\n\n  /* Payment Methods */\n  .payment-methods {\n    display: flex;\n    gap: 24px;\n    flex-wrap: wrap;\n  }\n\n  .payment-method {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    padding: 12px 16px;\n    background: rgba(0, 212, 170, 0.08);\n    border: 1px solid rgba(0, 212, 170, 0.2);\n    border-radius: 8px;\n    transition: all 0.3s ease;\n  }\n\n  .payment-method:hover {\n    background: rgba(0, 212, 170, 0.15);\n    border-color: var(--color-accent);\n  }\n\n  .payment-icon {\n    width: 20px;\n    height: 20px;\n    color: var(--color-accent);\n  }\n\n  .payment-method span {\n    font-size: 13px;\n    font-weight: 600;\n    color: var(--color-text-primary);\n    letter-spacing: 0.05em;\n  }\n\n  /* Savings Highlight */\n  .savings-highlight {\n    display: flex;\n    align-items: center;\n    gap: 32px;\n    padding: 24px;\n    background: rgba(201, 169, 110, 0.08);\n    border: 1px solid rgba(201, 169, 110, 0.2);\n    border-radius: 12px;\n    margin: 16px 0;\n  }\n\n  .savings-item {\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n  }\n\n  .savings-label {\n    font-size: 12px;\n    color: var(--color-text-secondary);\n    letter-spacing: 0.05em;\n    text-transform: uppercase;\n    font-weight: 600;\n  }\n\n  .savings-amount {\n    font-size: 24px;\n    font-weight: 700;\n    color: var(--color-gold);\n    letter-spacing: -0.01em;\n  }\n\n  .savings-divider {\n    width: 1px;\n    height: 40px;\n    background: rgba(201, 169, 110, 0.3);\n  }\n\n  /* CTA Button */\n  .prepaid-cta {\n    display: inline-block;\n    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);\n    color: #0F0F14;\n    padding: 16px 40px;\n    border-radius: 8px;\n    font-size: 14px;\n    font-weight: 700;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    text-decoration: none;\n    transition: all 0.3s ease;\n    border: none;\n    cursor: pointer;\n    width: fit-content;\n    box-shadow: 0 4px 16px rgba(0, 212, 170, 0.2);\n  }\n\n  .prepaid-cta:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 8px 24px rgba(0, 212, 170, 0.3);\n  }\n\n  /* Right Visual */\n  .prepaid-visual {\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    height: 300px;\n  }\n\n  /* Credit Card Visual */\n  .visual-card {\n    width: 100%;\n    max-width: 320px;\n    height: 200px;\n    background: linear-gradient(135deg, #00D4AA 0%, #00A080 100%);\n    border-radius: 16px;\n    padding: 24px;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n    box-shadow: 0 20px 60px rgba(0, 212, 170, 0.3);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .visual-card::before {\n    content: '';\n    position: absolute;\n    top: -50%;\n    right: -50%;\n    width: 300px;\n    height: 300px;\n    background: rgba(255, 255, 255, 0.1);\n    border-radius: 50%;\n    filter: blur(40px);\n  }\n\n  .card-chip {\n    width: 50px;\n    height: 40px;\n    background: rgba(255, 255, 255, 0.3);\n    border-radius: 6px;\n    position: relative;\n    z-index: 1;\n  }\n\n  .card-chip::before {\n    content: '';\n    position: absolute;\n    inset: 6px;\n    background: repeating-linear-gradient(\n      90deg,\n      rgba(255, 255, 255, 0.2) 0px,\n      rgba(255, 255, 255, 0.2) 4px,\n      transparent 4px,\n      transparent 8px\n    );\n    border-radius: 3px;\n  }\n\n  .card-number {\n    font-size: 18px;\n    font-weight: 600;\n    color: rgba(15, 15, 20, 0.8);\n    letter-spacing: 2px;\n    position: relative;\n    z-index: 1;\n  }\n\n  .card-holder {\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n    position: relative;\n    z-index: 1;\n  }\n\n  .card-label {\n    font-size: 10px;\n    font-weight: 700;\n    color: rgba(15, 15, 20, 0.6);\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n  }\n\n  .card-name {\n    font-size: 16px;\n    font-weight: 700;\n    color: rgba(15, 15, 20, 0.9);\n    letter-spacing: 0.05em;\n  }\n\n  /* Badge on Card */\n  .visual-badge {\n    position: absolute;\n    top: -20px;\n    right: -20px;\n    width: 140px;\n    height: 140px;\n    background: linear-gradient(135deg, var(--color-gold) 0%, #B8956A 100%);\n    border-radius: 50%;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    box-shadow: 0 12px 32px rgba(201, 169, 110, 0.3);\n    animation: float 3s ease-in-out infinite;\n  }\n\n  .badge-text {\n    font-size: 11px;\n    font-weight: 700;\n    color: #0F0F14;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n  }\n\n  .badge-amount {\n    font-size: 24px;\n    font-weight: 700;\n    color: #0F0F14;\n    letter-spacing: -0.01em;\n  }\n\n  @keyframes float {\n    0%, 100% {\n      transform: translateY(0px);\n    }\n    50% {\n      transform: translateY(-12px);\n    }\n  }\n\n  /* Trust Line */\n  .prepaid-trust {\n    display: flex;\n    justify-content: center;\n    gap: 40px;\n    margin-top: 60px;\n    padding-top: 40px;\n    border-top: 1px solid var(--color-border);\n    flex-wrap: wrap;\n  }\n\n  .trust-line-item {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n\n  .trust-line-icon {\n    width: 20px;\n    height: 20px;\n    color: var(--color-accent);\n    flex-shrink: 0;\n  }\n\n  .trust-line-item span {\n    font-size: 13px;\n    color: var(--color-text-secondary);\n    font-weight: 500;\n  }\n\n  /* Mobile Responsive */\n  @media (max-width: 768px) {\n    .blissway-prepaid-incentive {\n      padding: 40px 16px;\n    }\n\n    .prepaid-container {\n      grid-template-columns: 1fr;\n      gap: 40px;\n    }\n\n    .prepaid-visual {\n      height: 250px;\n    }\n\n    .prepaid-title {\n      font-size: 28px;\n    }\n\n    .payment-methods {\n      gap: 12px;\n    }\n\n    .payment-method {\n      flex: 1;\n      justify-content: center;\n    }\n\n    .savings-highlight {\n      gap: 16px;\n      padding: 16px;\n    }\n\n    .savings-divider {\n      display: none;\n    }\n\n    .savings-item {\n      flex: 1;\n      text-align: center;\n    }\n\n    .prepaid-trust {\n      gap: 20px;\n      margin-top: 40px;\n      padding-top: 30px;\n    }\n\n    .trust-line-item span {\n      font-size: 12px;\n    }\n  }\n\n  /* Tablet */\n  @media (max-width: 1024px) {\n    .prepaid-container {\n      gap: 40px;\n    }\n\n    .prepaid-visual {\n      height: 280px;\n    }\n  }\n\n  /* Dark Mode Support */\n  @media (prefers-color-scheme: dark) {\n    .blissway-prepaid-incentive {\n      background: linear-gradient(135deg, #1A1A22 0%, #0F0F14 100%);\n    }\n  }\n</style>",
        "color_scheme": "",
