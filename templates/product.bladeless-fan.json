    "custom_liquid_A68LeK": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n   :root {\n    --ink:      #111010;\n    --warm:     #f7f3ee;\n    --fog:      #f0ece6;\n    --orange:   #d94f1e;\n    --gold:     #b8892a;\n    --mist:     #e8f0f5;\n    --rule:     #ddd8d0;\n    --note:     #7a736b;\n    --white:    #ffffff;\n    --green:    #2a6e3f;\n  }\nbody {\n    font-family: 'DM Sans', sans-serif;\n    background: #eceae5;\n    color: var(--ink);\n    font-size: 15px;\n  }\n  /* ── LEGEND ── */\n  .legend {\n    background: var(--ink);\n    color: #ccc;\n    padding: 9px 28px;\n    font-size: 11px;\n    font-family: monospace;\n    display: flex;\n    gap: 20px;\n    flex-wrap: wrap;\n    align-items: center;\n    position: sticky;\n    top: 0;\n    z-index: 200;\n    letter-spacing: 0.5px;\n  }\n  .legend strong { color: #fff; margin-right: 6px; }\n  .pill {\n    padding: 2px 9px;\n    border-radius: 20px;\n    font-size: 10px;\n    font-weight: 600;\n    letter-spacing: 1px;\n    text-transform: uppercase;\n    display: inline-block;\n    margin-bottom: 8px;\n  }\n  .pill-h    { background: #fde8de; color: #c03a0e; }\n  .pill-b    { background: #ddeeff; color: #1a5fa0; }\n  .pill-ui   { background: #ddf0e0; color: #1d6636; }\n  .pill-tip  { background: #fff3cc; color: #7a5c00; border: 1px dashed #c8a020; }\n\n  /* ── WRAPPER ── */\n  .wrapper {\n    max-width: 900px;\n    margin: 0 auto;\n    padding: 40px 24px 120px;\n  }\n\n  /* ── SECTION DIVIDER ── */\n  .sec-label {\n    font-family: monospace;\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--note);\n    margin: 44px 0 10px;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n  .sec-label::after { content: ''; flex: 1; height: 1px; background: var(--rule); }\n\n  /* ── COPY CARD ── */\n  .card {\n    background: var(--white);\n    border: 1px solid var(--rule);\n    border-radius: 6px;\n    padding: 28px 32px;\n    margin-bottom: 12px;\n  }\n\n  /* ── TIP BOX ── */\n  .tip {\n    background: #fffbea;\n    border: 1px dashed #d4a820;\n    border-radius: 5px;\n    padding: 13px 18px;\n    font-size: 12.5px;\n    color: #6b4f00;\n    line-height: 1.6;\n    margin: 14px 0;\n  }\n  .tip strong { color: #3d2c00; }\n\n  /* ── HEADLINES ── */\n  h1.page-title {\n    font-family: 'Cormorant Garamond', Georgia, serif;\n    font-size: clamp(34px, 6vw, 54px);\n    font-weight: 700;\n    line-height: 1.08;\n    letter-spacing: -1px;\n    color: var(--ink);\n  }\n  h1.page-title em {\n    font-style: italic;\n    color: var(--orange);\n  }\n  .tagline {\n    font-family: 'Syne', sans-serif;\n    font-size: 15px;\n    font-weight: 500;\n    color: var(--note);\n    line-height: 1.6;\n    margin-top: 10px;\n    max-width: 520px;\n  }\n  h2.section-h {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 28px;\n    font-weight: 700;\n    color: var(--ink);\n    margin-bottom: 4px;\n  }\n  h3.block-h {\n    font-family: 'Syne', sans-serif;\n    font-size: 15px;\n    font-weight: 700;\n    color: var(--ink);\n    margin-bottom: 6px;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n  }\n\n  /* ── PRICE ── */\n  .price-row {\n    display: flex;\n    align-items: baseline;\n    gap: 14px;\n    margin: 18px 0 6px;\n    flex-wrap: wrap;\n  }\n  .price-now {\n    font-family: 'Syne', sans-serif;\n    font-size: 38px;\n    font-weight: 800;\n    color: var(--ink);\n  }\n  .price-was {\n    font-size: 20px;\n    text-decoration: line-through;\n    color: #bbb;\n  }\n  .price-save {\n    background: var(--orange);\n    color: #fff;\n    font-size: 11px;\n    font-weight: 700;\n    padding: 4px 10px;\n    border-radius: 2px;\n    letter-spacing: 1px;\n    text-transform: uppercase;\n  }\n  .price-meta {\n    font-size: 12px;\n    color: var(--note);\n    margin-bottom: 4px;\n  }\n  .emi-chip {\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    background: var(--fog);\n    border: 1px solid var(--rule);\n    border-radius: 3px;\n    padding: 6px 13px;\n    font-size: 12.5px;\n    color: var(--note);\n    margin-top: 6px;\n  }\n\n  /* ── BADGES ── */\n  .badge-row {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 8px;\n    margin: 16px 0;\n  }\n  .badge {\n    display: flex;\n    align-items: center;\n    gap: 7px;\n    border: 1px solid var(--rule);\n    border-radius: 3px;\n    padding: 7px 13px;\n    font-size: 12.5px;\n    background: var(--fog);\n    font-weight: 500;\n  }\n\n  /* ── PRODUCT IMAGE STRIP ── */\n  .img-strip {\n    display: grid;\n    grid-template-columns: 2fr 1fr 1fr;\n    gap: 6px;\n    border-radius: 6px;\n    overflow: hidden;\n    margin: 14px 0;\n  }\n  .img-strip img {\n    width: 100%;\n    height: 200px;\n    object-fit: cover;\n    display: block;\n  }\n  .img-strip img:first-child { height: 100%; }\n  .img-strip .col2 { display: flex; flex-direction: column; gap: 6px; }\n  .img-strip .col2 img { height: 97px; }\n\n  /* ── PAIN HOOK ── */\n  .pain-block {\n    background: var(--ink);\n    color: #f0ece6;\n    padding: 28px 32px;\n    border-radius: 6px;\n    margin: 8px 0;\n  }\n  .pain-block .pain-headline {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 26px;\n    font-weight: 700;\n    color: #fff;\n    line-height: 1.2;\n    margin-bottom: 12px;\n  }\n  .pain-block p {\n    font-size: 14.5px;\n    line-height: 1.7;\n    color: #c8c0b5;\n    max-width: 600px;\n  }\n  .pain-block p strong { color: #fff; }\n  .pain-block .highlight {\n    display: inline-block;\n    background: var(--orange);\n    color: #fff;\n    padding: 2px 8px;\n    border-radius: 2px;\n    font-weight: 600;\n  }\n\n  /* ── FEATURE GRID ── */\n  .feat-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n    gap: 12px;\n    margin-top: 10px;\n  }\n  .feat-card {\n    background: var(--fog);\n    border: 1px solid var(--rule);\n    border-radius: 5px;\n    padding: 18px 20px;\n  }\n  .feat-icon { font-size: 26px; margin-bottom: 8px; display: block; }\n  .feat-title {\n    font-family: 'Syne', sans-serif;\n    font-weight: 700;\n    font-size: 13px;\n    text-transform: uppercase;\n    letter-spacing: 0.5px;\n    margin-bottom: 5px;\n    color: var(--ink);\n  }\n  .feat-desc { font-size: 13px; color: var(--note); line-height: 1.5; }\n  .feat-desc strong { color: var(--ink); }\n\n  /* ── VS TABLE ── */\n  .vs-table { width: 100%; border-collapse: collapse; font-size: 13.5px; }\n  .vs-table th {\n    padding: 11px 16px;\n    font-family: 'Syne', sans-serif;\n    font-size: 11px;\n    letter-spacing: 1px;\n    text-transform: uppercase;\n    font-weight: 700;\n    text-align: center;\n  }\n  .vs-table th:first-child { text-align: left; background: var(--fog); }\n  .vs-table th.col-airluxe {\n    background: var(--orange);\n    color: #fff;\n  }\n  .vs-table th.col-regular { background: #ddd; color: #555; }\n  .vs-table td {\n    padding: 10px 16px;\n    border-bottom: 1px solid var(--rule);\n    text-align: center;\n  }\n  .vs-table td:first-child { text-align: left; color: var(--note); font-weight: 500; background: var(--fog); }\n  .vs-table .col-airluxe-td { background: #fff5f2; font-weight: 600; }\n  .vs-table .col-regular-td { background: #f9f9f9; color: #888; }\n  .vs-table tr:last-child td { border-bottom: none; }\n  .yes { color: var(--green); }\n  .no  { color: #c0392b; }\n\n  /* ── BULLET LIST ── */\n  .copy-list { list-style: none; }\n  .copy-list li {\n    display: flex;\n    gap: 10px;\n    padding: 10px 0;\n    border-bottom: 1px solid #f0ece6;\n    font-size: 14px;\n    line-height: 1.55;\n    color: var(--ink);\n  }\n  .copy-list li:last-child { border-bottom: none; }\n  .copy-list .ico { flex-shrink: 0; font-size: 18px; margin-top: 0; }\n\n  /* ── SPEC TABLE ── */\n  .spec-table { width: 100%; border-collapse: collapse; font-size: 13.5px; }\n  .spec-table td { padding: 9px 14px; border-bottom: 1px solid var(--rule); }\n  .spec-table td:first-child { color: var(--note); width: 42%; font-weight: 500; background: var(--fog); }\n  .spec-table tr:last-child td { border-bottom: none; }\n\n  /* ── FAQ ── */\n  .faq { border-top: 1px solid var(--rule); }\n  .faq-item { border-bottom: 1px solid var(--rule); padding: 16px 4px; }\n  .faq-q { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px; margin-bottom: 6px; }\n  .faq-a { font-size: 13.5px; color: var(--note); line-height: 1.65; }\n\n  /* ── REVIEWS ── */\n  .review-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));\n    gap: 12px;\n    margin-top: 10px;\n  }\n  .review-card {\n    background: var(--fog);\n    border: 1px solid var(--rule);\n    border-radius: 5px;\n    padding: 16px 18px;\n  }\n  .stars { color: #e8a020; font-size: 15px; margin-bottom: 7px; }\n  .review-text { font-size: 13.5px; line-height: 1.6; color: var(--ink); font-style: italic; margin-bottom: 10px; }\n  .reviewer { font-size: 11.5px; color: var(--note); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }\n  .verified { color: var(--green); font-size: 10.5px; margin-left: 6px; }\n\n  /* ── CTA BUTTONS ── */\n  .cta-row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 18px; }\n  .btn-primary {\n    background: var(--orange);\n    color: #fff;\n    border: none;\n    padding: 16px 36px;\n    font-size: 15px;\n    font-weight: 600;\n    border-radius: 3px;\n    cursor: pointer;\n    font-family: 'Syne', sans-serif;\n    letter-spacing: 0.3px;\n    text-transform: uppercase;\n  }\n  .btn-secondary {\n    background: transparent;\n    color: var(--ink);\n    border: 1.5px solid var(--ink);\n    padding: 15px 28px;\n    font-size: 14px;\n    font-weight: 600;\n    border-radius: 3px;\n    cursor: pointer;\n    font-family: 'Syne', sans-serif;\n    text-transform: uppercase;\n  }\n\n  /* ── SCARCITY BAR ── */\n  .scarcity {\n    background: #fff5f2;\n    border: 1px solid #f4c4b2;\n    border-radius: 4px;\n    padding: 11px 18px;\n    font-size: 13px;\n    color: #8b2c0d;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    margin-top: 14px;\n    font-weight: 500;\n  }\n  .stock-bar { flex: 1; height: 5px; background: #f4c4b2; border-radius: 10px; overflow: hidden; }\n  .stock-fill { height: 100%; width: 22%; background: var(--orange); border-radius: 10px; }\n\n  /* ── STICKY FOOTER ── */\n  .sticky-footer {\n    position: fixed;\n    bottom: 0;\n    left: 0;\n    right: 0;\n    background: #fff;\n    border-top: 1px solid var(--rule);\n    padding: 12px 24px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 12px;\n    box-shadow: 0 -6px 24px rgba(0,0,0,0.08);\n    z-index: 150;\n  }\n  .sticky-product { display: flex; align-items: center; gap: 12px; }\n  .sticky-product img { width: 44px; height: 44px; object-fit: cover; border-radius: 4px; border: 1px solid var(--rule); }\n  .sticky-name { font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 700; }\n  .sticky-price { font-size: 12px; color: var(--note); }\n\n  @media (max-width: 600px) {\n    .wrapper { padding: 24px 14px 130px; }\n    .img-strip { grid-template-columns: 1fr; }\n    .img-strip img { height: 240px; }\n    .img-strip .col2 { flex-direction: row; }\n    .img-strip .col2 img { height: 120px; flex: 1; }\n    .card { padding: 20px 18px; }\n    .pain-block { padding: 22px 20px; }\n  }\n</style>\n\n<div class=\"card\">\n<h2 class=\"section-h\">Why AirLuxe? </h2>\n<h3>Let the comparison speak.</h3>\n<p style=\"font-size: 14px; color: var(--note); margin-bottom: 18px;\">Not all fans are built equal. Here's what you're actually getting.</p>\n<div class=\"pill pill-b\">Comparison Table</div>\n<div style=\"overflow-x: auto;\">\n<table class=\"vs-table\" style=\"width: 100.016%; height: 501.241px;\">\n<thead>\n<tr style=\"height: 53.3333px;\">\n<th style=\"text-align: left; background: var(--fog); width: 28.9944%; height: 53.3333px;\">Feature</th>\n<th class=\"col-airluxe\" style=\"width: 24.8804%; height: 53.3333px;\">AirLuxe</th>\n<th class=\"col-regular\" style=\"width: 25.4681%; height: 53.3333px;\">Regular Table Fan</th>\n<th class=\"col-regular\" style=\"width: 20.5704%; height: 53.3333px;\">Ceiling Fan</th>\n</tr>\n</thead>\n<tbody>\n<tr style=\"height: 58.3507px;\">\n<td style=\"width: 28.9944%; height: 58.3507px;\">Safe around kids &amp; pets</td>\n<td class=\"col-airluxe-td\" style=\"width: 24.8804%; height: 58.3507px;\"><span class=\"yes\">✔ No blades</span></td>\n<td class=\"col-regular-td\" style=\"width: 25.4681%; height: 58.3507px;\"><span class=\"no\">✘ Sharp blades</span></td>\n<td class=\"col-regular-td\" style=\"width: 20.5704%; height: 58.3507px;\"><span class=\"no\">✘ Out of reach</span></td>\n</tr>\n<tr style=\"height: 58.3507px;\">\n<td style=\"width: 28.9944%; height: 58.3507px;\">Works during power cuts</td>\n<td class=\"col-airluxe-td\" style=\"width: 24.8804%; height: 58.3507px;\"><span class=\"yes\">✔ 3500mAh battery</span></td>\n<td class=\"col-regular-td\" style=\"width: 25.4681%; height: 58.3507px;\"><span class=\"no\">✘ Needs power</span></td>\n<td class=\"col-regular-td\" style=\"width: 20.5704%; height: 58.3507px;\"><span class=\"no\">✘ Needs power</span></td>\n</tr>\n<tr style=\"height: 58.3507px;\">\n<td style=\"width: 28.9944%; height: 58.3507px;\">Zoom-call friendly (quiet)</td>\n<td class=\"col-airluxe-td\" style=\"width: 24.8804%; height: 58.3507px;\"><span class=\"yes\">✔ Brushless motor</span></td>\n<td class=\"col-regular-td\" style=\"width: 25.4681%; height: 58.3507px;\"><span class=\"no\">✘ Audible hum</span></td>\n<td class=\"col-regular-td\" style=\"width: 20.5704%; height: 58.3507px;\"><span class=\"no\">✘ Wobble noise</span></td>\n</tr>\n<tr style=\"height: 58.3507px;\">\n<td style=\"width: 28.9944%; height: 58.3507px;\">Cool mist humidification</td>\n<td class=\"col-airluxe-td\" style=\"width: 24.8804%; height: 58.3507px;\"><span class=\"yes\">✔ Built-in mist</span></td>\n<td class=\"col-regular-td\" style=\"width: 25.4681%; height: 58.3507px;\"><span class=\"no\">✘ Air only</span></td>\n<td class=\"col-regular-td\" style=\"width: 20.5704%; height: 58.3507px;\"><span class=\"no\">✘ Air only</span></td>\n</tr>\n<tr style=\"height: 58.3507px;\">\n<td style=\"width: 28.9944%; height: 58.3507px;\">Targeted desk airflow</td>\n<td class=\"col-airluxe-td\" style=\"width: 24.8804%; height: 58.3507px;\"><span class=\"yes\">✔ 60° oscillation</span></td>\n<td class=\"col-regular-td\" style=\"width: 25.4681%; height: 58.3507px;\">Partial</td>\n<td class=\"col-regular-td\" style=\"width: 20.5704%; height: 58.3507px;\"><span class=\"no\">✘ Whole room</span></td>\n</tr>\n<tr style=\"height: 39.4531px;\">\n<td style=\"width: 28.9944%; height: 39.4531px;\">Night light</td>\n<td class=\"col-airluxe-td\" style=\"width: 24.8804%; height: 39.4531px;\"><span class=\"yes\">✔ 3-level LED</span></td>\n<td class=\"col-regular-td\" style=\"width: 25.4681%; height: 39.4531px;\"><span class=\"no\">✘ None</span></td>\n<td class=\"col-regular-td\" style=\"width: 20.5704%; height: 39.4531px;\"><span class=\"no\">✘ None</span></td>\n</tr>\n<tr style=\"height: 58.3507px;\">\n<td style=\"width: 28.9944%; height: 58.3507px;\">Sleep timer</td>\n<td class=\"col-airluxe-td\" style=\"width: 24.8804%; height: 58.3507px;\"><span class=\"yes\">✔ Up to 9 hours</span></td>\n<td class=\"col-regular-td\" style=\"width: 25.4681%; height: 58.3507px;\"><span class=\"no\">✘ Manual only</span></td>\n<td class=\"col-regular-td\" style=\"width: 20.5704%; height: 58.3507px;\"><span class=\"no\">✘ Rarely</span></td>\n</tr>\n<tr style=\"height: 58.3507px;\">\n<td style=\"width: 28.9944%; height: 58.3507px;\">Electricity cost per hour</td>\n<td class=\"col-airluxe-td\" style=\"width: 24.8804%; height: 58.3507px;\"><span class=\"yes\">~₹0.10 (USB-C)</span></td>\n<td class=\"col-regular-td\" style=\"width: 25.4681%; height: 58.3507px;\">~₹0.50–1.20</td>\n<td class=\"col-regular-td\" style=\"width: 20.5704%; height: 58.3507px;\">~₹1.50–3.00</td>\n</tr>\n</tbody>\n</table>\n</div>\n</div>",
