{{ 'bw-product-drawers.css' | asset_url | stylesheet_tag }}

{%- liquid
  # Grab the JSON array from custom.custom_product_drawers
  assign drawers_array = product.metafields.custom.custom_product_drawers.value
  assign sid = block.id | default: section.id | replace: '-', '_'
-%}

{%- if drawers_array != blank -%}

<style>
  #bw-drawers-{{ sid }} .bw-drawers__btn {
    font-size: {{ block.settings.font_size_mobile | default: 13 }}px;
  }
  #bw-drawer-{{ sid }} .bw-di__header,
  #bw-drawer-{{ sid }} .bw-di__inner,
  #bw-drawer-{{ sid }} .bw-di__inner p {
    font-size: {{ block.settings.content_font_size_mobile | default: 14 }}px;
  }
  @media screen and (min-width: 750px) {
    #bw-drawers-{{ sid }} .bw-drawers__btn {
      font-size: {{ block.settings.font_size_desktop | default: 13 }}px;
    }
    #bw-drawer-{{ sid }} .bw-di__header,
    #bw-drawer-{{ sid }} .bw-di__inner,
    #bw-drawer-{{ sid }} .bw-di__inner p {
      font-size: {{ block.settings.content_font_size_desktop | default: 14 }}px;
    }
  }
</style>

<div
  class="bw-drawers"
  id="bw-drawers-{{ sid }}"
  data-section-id="{{ sid }}"
>

  {%- comment -%} TRIGGER LIST (The Labels) {%- endcomment -%}
  <div class="bw-drawers__triggers">
    <ul class="bw-drawers__list" role="list">
      {%- for drawer in drawers_array -%}
        <li class="bw-drawers__item">
          <button
            class="bw-drawers__btn"
            type="button"
            aria-expanded="false"
            aria-controls="bw-drawer-{{ sid }}"
            data-drawer-index="{{ forloop.index0 }}"
          >
            <span style="display:flex; align-items:center; gap: 8px;">
              {%- if block.settings.icon and block.settings.icon != 'none' -%}
                {% render 'icon-accordion', icon: block.settings.icon %}
              {%- endif -%}
              <span>{{ drawer.label }}</span>
            </span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </button>
        </li>
      {%- endfor -%}
    </ul>
  </div>


  {%- comment -%} PRE-RENDERED DRAWER PANELS (The inner accordions) {%- endcomment -%}
  <div class="bw-drawer-panels" style="display:none" aria-hidden="true">
    {%- for drawer in drawers_array -%}
      <div
        class="bw-drawer-panel"
        id="bw-panel-{{ sid }}-{{ forloop.index0 }}"
        data-label="{{ drawer.label | escape }}"
      >
        {%- for item in drawer.items -%}
          <div class="bw-di">
            {%- if item.heading != blank -%}
              <button class="bw-di__header" type="button" aria-expanded="false">
                <span>{{ item.heading }}</span>
                <span class="bw-di__icon" aria-hidden="true"><span></span><span></span></span>
              </button>
              <div class="bw-di__body" role="region">
                <div class="bw-di__inner">{{ item.body }}</div>
              </div>
            {%- else -%}
              <div class="bw-di__body bw-di__body--always-open">
                <div class="bw-di__inner">{{ item.body }}</div>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endfor -%}
  </div>


  {%- comment -%} DRAWER SHELL {%- endcomment -%}
  <div
    class="bw-drawer"
    id="bw-drawer-{{ sid }}"
    role="dialog"
    aria-modal="true"
    aria-labelledby="bw-drawer-title-{{ sid }}"
    aria-hidden="true"
  >
    <div class="bw-drawer__inner">
      <div class="bw-drawer__header">
        <p class="bw-drawer__title" id="bw-drawer-title-{{ sid }}"></p>
        <button
          class="bw-drawer__close"
          type="button"
          aria-label="{{ 'accessibility.close' | t | default: 'Close' }}"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div
        class="bw-drawer__body"
        id="bw-drawer-body-{{ sid }}"
      ></div>
    </div>
  </div>


  {%- comment -%} Overlay {%- endcomment -%}
  <div
    class="bw-drawer-overlay"
    id="bw-drawer-overlay-{{ sid }}"
    aria-hidden="true"
  ></div>

</div>

<script src="{{ 'bw-product-drawers.js' | asset_url }}" defer></script>

{%- endif -%}
