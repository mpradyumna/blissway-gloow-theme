{% comment %}
  Sticky Cart Notification Bar (CRO)
  Shows item count, total price, and View Cart button at the bottom of the screen.
{% endcomment %}

<style>
  #sticky-cart-notification {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%) translateY(120%);
    z-index: 99999;
    background-color: #000;
    color: #fff;
    box-shadow: 0 8px 30px rgba(0,0,0,0.3);
    padding: 12px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 15px;
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    border-radius: 50px;
    width: calc(100% - 40px);
    max-width: 400px;
  }

  #sticky-cart-notification.active {
    transform: translateX(-50%) translateY(0);
  }

  .sticky-cart-info {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.3rem;
    line-height: 1;
    white-space: nowrap;
  }

  .sticky-cart-price {
    color: #4ade80; /* Light green */
    font-weight: 700;
  }

  .sticky-cart-btn {
    background-color: #fff;
    color: #000;
    padding: 8px 16px;
    border-radius: 25px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
  }

  @media screen and (min-width: 750px) {
    #sticky-cart-notification {
      left: auto;
      right: 30px;
      transform: translateY(120%);
      border-radius: 12px;
      width: auto;
    }
    #sticky-cart-notification.active {
      transform: translateY(0);
    }
  }
</style>

<div id="sticky-cart-notification" {% if cart.item_count > 0 %}class="active"{% endif %}>
  <div class="sticky-cart-info">
    <span class="sticky-cart-items">{{ cart.item_count }} {{ cart.item_count | pluralize: 'Item', 'Items' }}</span>
    <span class="sticky-cart-price">{{ cart.total_price | money }}</span>
  </div>
  <a href="{{ routes.cart_url }}" class="sticky-cart-btn" onclick="openCartDrawer(event)">View Cart</a>
</div>

<script>
  function openCartDrawer(e) {
    const cartDrawer = document.querySelector('cart-drawer');
    if (cartDrawer && typeof cartDrawer.open === 'function') {
      e.preventDefault();
      cartDrawer.open();
    }
  }

  function formatMoney(cents) {
    if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
      return Shopify.formatMoney(cents);
    }
    // Very simple fallback: assume 2 decimals
    return 'Rs. ' + (cents / 100).toLocaleString('en-IN', { minimumFractionDigits: 2 });
  }

  // Update logic when cart changes using theme's pubsub
  document.addEventListener('DOMContentLoaded', function() {
    if (typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined') {
      subscribe(PUB_SUB_EVENTS.cartUpdate, function(event) {
        const cart = event.cartData || event;
        const bar = document.getElementById('sticky-cart-notification');
        console.log("listener for sticky-cart-notification ") 
        console.log("sticky-cart-notification "+bar) 
        console.log(" Event Source : " + event.source)
        if (!bar) return;

        if (cart && cart.item_count > 0) {
          bar.querySelector('.sticky-cart-items').textContent = cart.item_count + ' ' + (cart.item_count === 1 ? 'Item' : 'Items');
          bar.querySelector('.sticky-cart-price').textContent = formatMoney(cart.total_price);
          bar.classList.add('active');

          // Flash effect for toast
          if (event.source === 'product-form') {
            const btn = bar.querySelector('.sticky-cart-btn');
            const originalText = 'VIEW CART';
            btn.textContent = 'ADDED! ✓';
            btn.style.backgroundColor = '#137333';
            setTimeout(() => {
               btn.textContent = originalText;
               btn.style.backgroundColor = '';
            }, 2500);
          }
        } else {
          bar.classList.remove('active');
        }
      });
    }
  });
</script>
